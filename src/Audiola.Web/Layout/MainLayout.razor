@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudIcon Icon="@Icons.Material.Filled.GraphicEq" Class="mr-2" />
        <MudText Typo="Typo.h6">Audiola</MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="_open" Elevation="2" ClipMode="DrawerClipMode.Always" Variant="DrawerVariant.Responsive">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Start</MudNavLink>
            <MudNavLink Href="/studio" Icon="@Icons.Material.Filled.GraphicEq">Studio</MudNavLink>
            <MudNavLink Href="/equalizer" Icon="@Icons.Material.Filled.Equalizer">Equalizer</MudNavLink>
            <MudNavLink Href="/mastering" Icon="@Icons.Material.Filled.Tune">Mastering</MudNavLink>
            <MudNavLink Href="/variations" Icon="@Icons.Material.Filled.AutoFixHigh">Variationen</MudNavLink>
            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">Einstellungen</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _open = true;
    private void ToggleDrawer() => _open = !_open;
}
