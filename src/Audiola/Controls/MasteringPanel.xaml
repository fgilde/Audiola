<UserControl
    x:Class="Audiola.Controls.MasteringPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:Audiola.Controls">

    <!-- Gemeinsames Mastering-Panel: identisch auf der Mastering-Seite (Studio-Mix) und im
         „Spur mastern"-Dialog (Einzelspur). DataContext = MasteringViewModel. -->
    <StackPanel>
        <!-- Vorschau & A/B -->
        <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Text="Vorschau" />
        <ui:Card Padding="14">
            <StackPanel>
                <controls:WaveformControl x:Name="Waveform" Height="70" Cursor="Hand"
                                          MouseLeftButtonDown="Waveform_MouseDown"
                                          Peaks="{Binding MixPeaks}"
                                          Progress="{Binding Transport.Progress}"
                                          ToolTip="Klicken zum Springen" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                    <ui:Button Width="44" Icon="{ui:SymbolIcon Play24}" Command="{Binding Transport.PlayPauseCommand}" />
                    <ui:Button Width="44" Margin="6,0,0,0" Icon="{ui:SymbolIcon Stop24}" Command="{Binding Transport.StopCommand}" />
                    <ui:ToggleSwitch Margin="16,0,0,0" VerticalAlignment="Center" Content="Master (A/B)"
                                     IsChecked="{Binding PreviewMaster, Mode=TwoWay}"
                                     ToolTip="Mastering live an/aus schalten und vergleichen" />
                    <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding StatusText}" />
                </StackPanel>
            </StackPanel>
        </ui:Card>

        <!-- Profile -->
        <TextBlock Margin="0,20,0,8" FontWeight="SemiBold" Text="Preset" />
        <ui:Card Padding="16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Wand24" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <ComboBox Width="240" VerticalAlignment="Center"
                              ItemsSource="{Binding ProfileNames}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}" />
                    <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Delete24}" Content="Löschen"
                               Command="{Binding DeleteProfileCommand}" ToolTip="Eigenes Profil löschen" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="36,10,0,0">
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Eigenes Profil:" />
                    <ui:TextBox Width="200" Margin="8,0,0,0" PlaceholderText="Name…"
                                Text="{Binding NewProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Save24}" Content="Speichern"
                               Command="{Binding SaveProfileCommand}" />
                </StackPanel>
            </StackPanel>
        </ui:Card>

        <!-- Bearbeitung (Karten nebeneinander) -->
        <WrapPanel Margin="0,18,0,0">
            <ui:Card Width="352" Margin="0,0,12,12" Padding="16">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Equalizer" Margin="0,0,0,8" />
                    <!-- Live-Frequenzgang -->
                    <Border Height="118" Margin="0,0,0,10" CornerRadius="8" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1E2230" Offset="0" />
                                <GradientStop Color="#14161E" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Stretch="Fill">
                            <Canvas Width="1000" Height="200">
                                <Line X1="0" Y1="100" X2="1000" Y2="100" Stroke="#3A3F4C" StrokeThickness="1.5" />
                                <Line X1="0" Y1="55" X2="1000" Y2="55" Stroke="#262A34" StrokeThickness="1" />
                                <Line X1="0" Y1="145" X2="1000" Y2="145" Stroke="#262A34" StrokeThickness="1" />
                                <Polyline Points="{Binding EqCurve}" StrokeThickness="3.5"
                                          StrokeLineJoin="Round" Stroke="#6FA0FF">
                                    <Polyline.Effect>
                                        <DropShadowEffect Color="#5B8CFF" BlurRadius="12" ShadowDepth="0" Opacity="0.7" />
                                    </Polyline.Effect>
                                </Polyline>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <CheckBox Content="High-Pass aktiv" IsChecked="{Binding HighPassEnabled, Mode=TwoWay}" />
                    <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding HighPassHz, StringFormat='High-Pass: {0:F0} Hz'}" />
                    <Slider Minimum="20" Maximum="200" Value="{Binding HighPassHz, Mode=TwoWay}" />
                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding LowShelfGainDb, StringFormat='Bass: {0:+0.0;-0.0;0} dB'}" />
                    <Slider Minimum="-12" Maximum="12" Value="{Binding LowShelfGainDb, Mode=TwoWay}" />
                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding MidGainDb, StringFormat='Mitten: {0:+0.0;-0.0;0} dB'}" />
                    <Slider Minimum="-12" Maximum="12" Value="{Binding MidGainDb, Mode=TwoWay}" />
                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding HighShelfGainDb, StringFormat='Höhen: {0:+0.0;-0.0;0} dB'}" />
                    <Slider Minimum="-12" Maximum="12" Value="{Binding HighShelfGainDb, Mode=TwoWay}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Width="352" Margin="0,0,12,12" Padding="16">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Kompressor" Margin="0,0,0,8" />
                    <CheckBox Content="Kompressor aktiv" IsChecked="{Binding CompressorEnabled, Mode=TwoWay}" />
                    <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding ThresholdDb, StringFormat='Threshold: {0:F0} dB'}" />
                    <Slider Minimum="-48" Maximum="0" Value="{Binding ThresholdDb, Mode=TwoWay}" />
                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding Ratio, StringFormat='Ratio: {0:F1}:1'}" />
                    <Slider Minimum="1" Maximum="20" Value="{Binding Ratio, Mode=TwoWay}" />
                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding MakeupGainDb, StringFormat='Makeup: {0:+0.0;-0.0;0} dB'}" />
                    <Slider Minimum="0" Maximum="24" Value="{Binding MakeupGainDb, Mode=TwoWay}" />
                </StackPanel>
            </ui:Card>

            <ui:Card Width="352" Margin="0,0,12,12" Padding="16">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Loudness (LUFS)" Margin="0,0,0,8" />
                    <!-- LUFS-Lehre: Eingangslautheit auf der Skala −24 … −6 -->
                    <Grid Height="14" Margin="0,0,0,10">
                        <Border CornerRadius="7" Background="#20242E" />
                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding InputLufsPercent}"
                                     Background="Transparent" BorderThickness="0">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#2E7D32" Offset="0.0" />
                                    <GradientStop Color="#C0CA33" Offset="0.6" />
                                    <GradientStop Color="#E53935" Offset="1.0" />
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                    </Grid>
                    <TextBlock Margin="0,0,0,2" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding InputLufsLabel, StringFormat='Eingang: {0}'}" />
                    <CheckBox Content="Auf Ziel-Lautheit normalisieren" IsChecked="{Binding NormalizeLoudness, Mode=TwoWay}" />
                    <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding TargetLufs, StringFormat='Ziel: {0:F0} LUFS (Streaming ≈ -14)'}" />
                    <Slider Minimum="-24" Maximum="-6" Value="{Binding TargetLufs, Mode=TwoWay}" />
                    <ui:Button Margin="0,12,0,0" Icon="{ui:SymbolIcon Pulse24}" Content="LUFS messen" Command="{Binding AnalyzeCommand}" />
                </StackPanel>
            </ui:Card>
        </WrapPanel>

        <!-- Aktionen -->
        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
            <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon CheckmarkCircle24}" Content="Auf Spur anwenden"
                       Command="{Binding ApplyToTrackCommand}"
                       Visibility="{Binding IsTrackSource, Converter={StaticResource BooleanToVisibilityConverter}}"
                       ToolTip="Spur mastern und im Studio ersetzen (Strg+Z macht es rückgängig)" />
            <ui:Button Margin="0,0,0,0" Icon="{ui:SymbolIcon Save24}" Content="Mastern &amp; exportieren" Command="{Binding ExportCommand}">
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Appearance" Value="Primary" />
                        <Setter Property="Margin" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTrackSource}" Value="True">
                                <Setter Property="Appearance" Value="Secondary" />
                                <Setter Property="Margin" Value="8,0,0,0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
            <ui:ProgressRing Margin="16,0,0,0" VerticalAlignment="Center" IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
    </StackPanel>
</UserControl>
