<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Audiola Studio-Palette — DUNKEL. Dieselben Color-Keys wie DawColors.Light.xaml;
         die Brushes in DawTheme.xaml referenzieren sie per DynamicResource und wechseln
         damit automatisch, wenn dieses Dictionary getauscht wird. -->
    <Color x:Key="DawBg">#121318</Color>
    <Color x:Key="DawPanel">#1A1C23</Color>
    <Color x:Key="DawCard">#20232D</Color>
    <Color x:Key="DawHover">#2A2E3A</Color>
    <Color x:Key="DawStroke">#2C303B</Color>
    <Color x:Key="DawStrokeStrong">#3A3F4D</Color>
    <Color x:Key="DawText">#E9EBF2</Color>
    <Color x:Key="DawTextDim">#A7ADC0</Color>
    <Color x:Key="DawTextFaint">#757C90</Color>
    <Color x:Key="DawAccent">#3F8CFF</Color>
    <Color x:Key="DawAccentLight">#6BD6FF</Color>
    <Color x:Key="DawAccentViolet">#B56BFF</Color>
    <Color x:Key="DawAccentSoft">#2E3F8CFF</Color>
    <Color x:Key="DawGreen">#3DDC84</Color>
    <Color x:Key="DawYellow">#FFC24B</Color>
    <Color x:Key="DawRed">#FF5350</Color>
    <Color x:Key="DawRec">#FF3B30</Color>
    <!-- Timeline-Arbeitsfläche (Ruler/Lanes/Mixer) — dunkler „Screen" hinter Clips & Wellen. -->
    <Color x:Key="DawTimeline">#15151B</Color>
    <!-- Scrollbalken (halbtransparent, damit sie auf jeder Fläche funktionieren). -->
    <Color x:Key="DawScrollThumb">#66FFFFFF</Color>
    <Color x:Key="DawScrollTrack">#14FFFFFF</Color>
</ResourceDictionary>
