<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- ============================================================
         Audiola DAW-Theme — dunkle Studio-Optik.
         Überschreibt die WPF-UI-Systembrushes (DynamicResource), sodass
         ALLE bestehenden Views automatisch die Studio-Palette erhalten,
         und definiert eigene Daw*-Keys/-Styles für die Shell.
         ============================================================ -->

    <!-- ————— Palette ————— -->
    <Color x:Key="DawBg">#121318</Color>            <!-- Fenster-Grund -->
    <Color x:Key="DawPanel">#1A1C23</Color>         <!-- Panels/Docks -->
    <Color x:Key="DawCard">#20232D</Color>          <!-- erhöhte Flächen -->
    <Color x:Key="DawHover">#2A2E3A</Color>
    <Color x:Key="DawStroke">#2C303B</Color>
    <Color x:Key="DawStrokeStrong">#3A3F4D</Color>
    <Color x:Key="DawText">#E9EBF2</Color>
    <Color x:Key="DawTextDim">#A7ADC0</Color>
    <Color x:Key="DawTextFaint">#757C90</Color>
    <Color x:Key="DawAccent">#3F8CFF</Color>
    <Color x:Key="DawAccentLight">#6BD6FF</Color>
    <Color x:Key="DawAccentViolet">#B56BFF</Color>

    <SolidColorBrush x:Key="DawBgBrush" Color="{StaticResource DawBg}" />
    <SolidColorBrush x:Key="DawPanelBrush" Color="{StaticResource DawPanel}" />
    <SolidColorBrush x:Key="DawCardBrush" Color="{StaticResource DawCard}" />
    <SolidColorBrush x:Key="DawHoverBrush" Color="{StaticResource DawHover}" />
    <SolidColorBrush x:Key="DawStrokeBrush" Color="{StaticResource DawStroke}" />
    <SolidColorBrush x:Key="DawStrokeStrongBrush" Color="{StaticResource DawStrokeStrong}" />
    <SolidColorBrush x:Key="DawTextBrush" Color="{StaticResource DawText}" />
    <SolidColorBrush x:Key="DawTextDimBrush" Color="{StaticResource DawTextDim}" />
    <SolidColorBrush x:Key="DawTextFaintBrush" Color="{StaticResource DawTextFaint}" />
    <SolidColorBrush x:Key="DawAccentBrush" Color="{StaticResource DawAccent}" />
    <SolidColorBrush x:Key="DawAccentLightBrush" Color="{StaticResource DawAccentLight}" />
    <SolidColorBrush x:Key="DawAccentSoftBrush" Color="#2E3F8CFF" />
    <SolidColorBrush x:Key="DawGreenBrush" Color="#3DDC84" />
    <SolidColorBrush x:Key="DawYellowBrush" Color="#FFC24B" />
    <SolidColorBrush x:Key="DawRedBrush" Color="#FF5350" />
    <SolidColorBrush x:Key="DawRecBrush" Color="#FF3B30" />

    <!-- Marken-Gradient (Frequenzverlauf) — für Logo-Akzente und den Playhead-Glow. -->
    <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3F8CFF" Offset="0" />
        <GradientStop Color="#6BD6FF" Offset="0.5" />
        <GradientStop Color="#B56BFF" Offset="1" />
    </LinearGradientBrush>

    <!-- ————— Overrides der WPF-UI-Systembrushes —————
         Bestehende Views binden per DynamicResource an diese Keys;
         damit erbt jede Seite/jeder Dialog automatisch die Studio-Palette. -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource DawBg}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource DawBg}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{StaticResource DawPanel}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource DawPanel}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="{StaticResource DawCard}" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource DawCard}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource DawHover}" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{StaticResource DawStroke}" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource DawStrokeStrong}" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource DawText}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource DawTextDim}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource DawTextFaint}" />

    <!-- ————— Shell-Styles ————— -->

    <!-- Panel: die Grundfläche aller Docks/Karten (ersetzt das überall duplizierte Border-Muster). -->
    <Style x:Key="DawPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DawPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DawStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <!-- Abschnitts-Überschrift in Panels (kleine, gedimmte Caption). -->
    <Style x:Key="DawCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DawTextFaintBrush}" />
    </Style>

    <!-- Werkzeug-Button der Icon-Rail (links): quadratisch, ruhig, klarer Hover. -->
    <Style x:Key="DawRailButton" TargetType="Button">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource DawTextDimBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource DawHoverBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource DawTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource DawAccentSoftBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dock-Tab (unteres Panel): RadioButton als flacher Tab mit Akzent-Unterstreichung. -->
    <Style x:Key="DawDockTab" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource DawTextFaintBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" Padding="12,6" CornerRadius="6,6,0,0" Background="Transparent">
                        <StackPanel>
                            <ContentPresenter HorizontalAlignment="Center" />
                            <Rectangle x:Name="underline" Height="2" Margin="0,4,0,0"
                                       RadiusX="1" RadiusY="1" Fill="Transparent" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DawTextDimBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DawTextBrush}" />
                            <Setter TargetName="underline" Property="Fill" Value="{StaticResource BrandGradient}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Transport-Zeitanzeige: große Monospace-Ziffern wie im Studio. -->
    <Style x:Key="DawTimeDisplay" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DawTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Statusleisten-Text. -->
    <Style x:Key="DawStatusText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource DawTextFaintBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
