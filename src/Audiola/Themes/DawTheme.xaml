<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <!-- ============================================================
         Audiola DAW-Theme — dunkle Studio-Optik.
         Überschreibt die WPF-UI-Systembrushes (DynamicResource), sodass
         ALLE bestehenden Views automatisch die Studio-Palette erhalten,
         und definiert eigene Daw*-Keys/-Styles für die Shell.
         ============================================================ -->

    <!-- ————— Palette-Brushes —————
         Die Color-Keys (DawBg …) liefert ein separates, umschaltbares Dictionary
         (DawColors.Dark/Light.xaml). Deshalb hier DynamicResource: beim Theme-Wechsel
         wird nur das Farb-Dictionary getauscht, und alle Brushes ziehen automatisch mit. -->
    <SolidColorBrush x:Key="DawBgBrush" Color="{DynamicResource DawBg}" />
    <SolidColorBrush x:Key="DawPanelBrush" Color="{DynamicResource DawPanel}" />
    <SolidColorBrush x:Key="DawCardBrush" Color="{DynamicResource DawCard}" />
    <SolidColorBrush x:Key="DawHoverBrush" Color="{DynamicResource DawHover}" />
    <SolidColorBrush x:Key="DawStrokeBrush" Color="{DynamicResource DawStroke}" />
    <SolidColorBrush x:Key="DawStrokeStrongBrush" Color="{DynamicResource DawStrokeStrong}" />
    <SolidColorBrush x:Key="DawTextBrush" Color="{DynamicResource DawText}" />
    <SolidColorBrush x:Key="DawTextDimBrush" Color="{DynamicResource DawTextDim}" />
    <SolidColorBrush x:Key="DawTextFaintBrush" Color="{DynamicResource DawTextFaint}" />
    <SolidColorBrush x:Key="DawAccentBrush" Color="{DynamicResource DawAccent}" />
    <SolidColorBrush x:Key="DawAccentLightBrush" Color="{DynamicResource DawAccentLight}" />
    <SolidColorBrush x:Key="DawAccentSoftBrush" Color="{DynamicResource DawAccentSoft}" />
    <SolidColorBrush x:Key="DawGreenBrush" Color="{DynamicResource DawGreen}" />
    <SolidColorBrush x:Key="DawYellowBrush" Color="{DynamicResource DawYellow}" />
    <SolidColorBrush x:Key="DawRedBrush" Color="{DynamicResource DawRed}" />
    <SolidColorBrush x:Key="DawRecBrush" Color="{DynamicResource DawRec}" />
    <SolidColorBrush x:Key="DawTimelineBrush" Color="{DynamicResource DawTimeline}" />
    <SolidColorBrush x:Key="DawScrollThumbBrush" Color="{DynamicResource DawScrollThumb}" />
    <SolidColorBrush x:Key="DawScrollTrackBrush" Color="{DynamicResource DawScrollTrack}" />

    <!-- Marken-Gradient (Frequenzverlauf) — für Logo-Akzente und den Playhead-Glow. -->
    <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3F8CFF" Offset="0" />
        <GradientStop Color="#6BD6FF" Offset="0.5" />
        <GradientStop Color="#B56BFF" Offset="1" />
    </LinearGradientBrush>

    <!-- ————— Overrides der WPF-UI-Systembrushes —————
         Bestehende Views binden per DynamicResource an diese Keys;
         damit erbt jede Seite/jeder Dialog automatisch die Studio-Palette (Light + Dark). -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{DynamicResource DawBg}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{DynamicResource DawBg}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="{DynamicResource DawPanel}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{DynamicResource DawPanel}" />
    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="{DynamicResource DawCard}" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{DynamicResource DawCard}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{DynamicResource DawHover}" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{DynamicResource DawStroke}" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{DynamicResource DawStrokeStrong}" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{DynamicResource DawText}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{DynamicResource DawTextDim}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{DynamicResource DawTextFaint}" />

    <!-- ————— Shell-Styles ————— -->

    <!-- Panel: die Grundfläche aller Docks/Karten (ersetzt das überall duplizierte Border-Muster). -->
    <Style x:Key="DawPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DawPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DawStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <!-- Abschnitts-Überschrift in Panels (kleine, gedimmte Caption). -->
    <Style x:Key="DawCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DawTextFaintBrush}" />
    </Style>

    <!-- Werkzeug-Button der Icon-Rail (links): quadratisch, ruhig, klarer Hover. -->
    <Style x:Key="DawRailButton" TargetType="Button">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource DawTextDimBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource DawHoverBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource DawTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource DawAccentSoftBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dock-Tab (unteres Panel): RadioButton als flacher Tab mit Akzent-Unterstreichung. -->
    <Style x:Key="DawDockTab" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource DawTextFaintBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" Padding="12,6" CornerRadius="6,6,0,0" Background="Transparent">
                        <StackPanel>
                            <ContentPresenter HorizontalAlignment="Center" />
                            <Rectangle x:Name="underline" Height="2" Margin="0,4,0,0"
                                       RadiusX="1" RadiusY="1" Fill="Transparent" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DawTextDimBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DawTextBrush}" />
                            <Setter TargetName="underline" Property="Fill" Value="{StaticResource BrandGradient}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Transport-Zeitanzeige: große Monospace-Ziffern wie im Studio. -->
    <Style x:Key="DawTimeDisplay" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DawTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Statusleisten-Text. -->
    <Style x:Key="DawStatusText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource DawTextFaintBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Seiten-Titel: großer Kopf jeder Seite im Marken-Farbverlauf (statt geerbtem Schwarz). -->
    <Style x:Key="DawPageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrandGradient}" />
    </Style>

</ResourceDictionary>
