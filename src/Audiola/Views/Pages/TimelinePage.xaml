<Page
    x:Class="Audiola.Views.Pages.TimelinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:Audiola.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Title="TimelinePage">

    <Page.InputBindings>
        <KeyBinding Modifiers="Control" Key="Z" Command="{Binding ViewModel.UndoCommand}" />
        <KeyBinding Modifiers="Control" Key="Y" Command="{Binding ViewModel.RedoCommand}" />
    </Page.InputBindings>

    <Grid Margin="42,24,42,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Kopf -->
        <StackPanel Grid.Row="0">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Studio" />
            <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Mehrspur-Arbeitsfläche — Audiodateien hierher ziehen, Stems übernehmen, Clips schneiden &amp; mischen." />
        </StackPanel>

        <!-- Werkzeugleiste + Clip-Inspektor -->
        <StackPanel Grid.Row="1">
        <Border Margin="0,14,0,0" Padding="8,6" CornerRadius="10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <WrapPanel Orientation="Horizontal">
                <ui:Button Margin="0,0,4,0" Appearance="Primary" Icon="{ui:SymbolIcon Add24}"
                           Command="{Binding ViewModel.AddAudioCommand}" ToolTip="Audiodatei als Spur hinzufügen" />
                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon AddSquare24}"
                           Command="{Binding ViewModel.AddEmptyTrackCommand}" ToolTip="Leere Spur anlegen (Parts dorthin verschieben)" />
                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon Layer24}"
                           Command="{Binding ViewModel.ImportStemsCommand}" ToolTip="Aktuelle Stems als Spuren übernehmen" />
                <Border Width="1" Margin="6,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon ArrowUndo24}"
                           Command="{Binding ViewModel.UndoCommand}" ToolTip="Rückgängig (Strg+Z)" />
                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon ArrowRedo24}"
                           Command="{Binding ViewModel.RedoCommand}" ToolTip="Wiederholen (Strg+Y)" />
                <Border Width="1" Margin="6,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon Play24}" Command="{Binding ViewModel.PlayPauseCommand}" ToolTip="Abspielen / Pause" />
                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon Stop24}" Command="{Binding ViewModel.StopCommand}" ToolTip="Stopp" />
                <ui:ToggleSwitch Margin="6,0,0,0" VerticalAlignment="Center" IsChecked="{Binding ViewModel.LoopEnabled, Mode=TwoWay}" ToolTip="Auswahl loopen" />
                <Border Width="1" Margin="6,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon Cut24}" Command="{Binding ViewModel.SplitAtPlayheadCommand}" ToolTip="Clip am Playhead teilen" />
                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon EraserSegment24}" Command="{Binding ViewModel.CutRegionCommand}" ToolTip="Markierten Bereich aus dem Clip herausschneiden" />
                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon Delete24}" Command="{Binding ViewModel.DeleteSelectedCommand}" ToolTip="Clip löschen" />
                <ui:ToggleSwitch Margin="6,0,0,0" VerticalAlignment="Center" Content="Bereich"
                                 IsChecked="{Binding ViewModel.RangeSelectMode, Mode=TwoWay}"
                                 ToolTip="Auswahl-Werkzeug: in den Spuren ziehen, um einen Bereich zu markieren (Effekte/Cleanup wirken dann nur darauf)" />
                <Border Width="1" Margin="6,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon ZoomOut24}" Command="{Binding ViewModel.ZoomOutCommand}" ToolTip="Auszoomen" />
                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon ZoomIn24}" Command="{Binding ViewModel.ZoomInCommand}" ToolTip="Einzoomen" />
                <ui:ToggleSwitch Margin="6,0,0,0" VerticalAlignment="Center" IsChecked="{Binding ViewModel.SnapEnabled, Mode=TwoWay}" ToolTip="Einrasten" />
                <ComboBox Width="72" Margin="6,0,0,0" VerticalAlignment="Center"
                          ItemsSource="{Binding ViewModel.GridOptions}" SelectedItem="{Binding ViewModel.GridSeconds, Mode=TwoWay}"
                          ToolTip="Rasterweite (s)" />
                <Border Width="1" Margin="6,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon SelectObjectSkew24}" Command="{Binding ViewModel.ClearSelectionCommand}" ToolTip="Auswahl löschen" />
                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon Save24}" Command="{Binding ViewModel.ExportRangeCommand}" ToolTip="Auswahlbereich exportieren" />
                <Border Width="1" Margin="6,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon Wand24}" Content="Variationen" Click="Variations_All_Click"
                           ToolTip="Variationen-Provider auf das gesamte Audio (alle Spuren) anwenden" />
                <Border Width="1" Margin="6,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />
                <ui:ToggleSwitch VerticalAlignment="Center" Content="Mixer" IsChecked="{Binding ViewModel.ShowMixer, Mode=TwoWay}" ToolTip="Mixer-Panel ein-/ausblenden" />

                <ui:ProgressRing Width="20" Height="20" Margin="12,0,0,0" VerticalAlignment="Center" IsIndeterminate="True"
                                 Visibility="{Binding ViewModel.IsSeparating, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding ViewModel.SeparationStatus}"
                           Visibility="{Binding ViewModel.IsSeparating, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </WrapPanel>
        </Border>

        <!-- Clip-Inspektor (bei Auswahl) -->
        <Border Margin="0,8,0,0" Padding="12,8" CornerRadius="10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                Visibility="{Binding ViewModel.HasSelectedClip, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Options24" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Clip" />
                <StackPanel Margin="20,0,0,0" Width="160">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="{Binding ViewModel.SelectedClip.GainDb, StringFormat='Lautstärke: {0:+0.0;-0.0;0} dB'}" />
                    <Slider Minimum="-24" Maximum="6" Value="{Binding ViewModel.SelectedClip.GainDb, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Margin="16,0,0,0" Width="150">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="{Binding ViewModel.SelectedClip.FadeInSeconds, StringFormat='Fade-In: {0:F2} s'}" />
                    <Slider Minimum="0" Maximum="5" Value="{Binding ViewModel.SelectedClip.FadeInSeconds, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Margin="16,0,0,0" Width="150">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="{Binding ViewModel.SelectedClip.FadeOutSeconds, StringFormat='Fade-Out: {0:F2} s'}" />
                    <Slider Minimum="0" Maximum="5" Value="{Binding ViewModel.SelectedClip.FadeOutSeconds, Mode=TwoWay}" />
                </StackPanel>

                <Border Width="1" Margin="16,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding ViewModel.ClipEffectScope}" Margin="0,0,0,4" />
                    <WrapPanel>
                        <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon Sparkle24}" Content="Hall" Command="{Binding ViewModel.ClipReverbCommand}" />
                        <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon SoundWaveCircle24}" Content="Echo" Command="{Binding ViewModel.ClipEchoCommand}" />
                        <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon Gauge24}" Content="Norm." Command="{Binding ViewModel.ClipNormalizeCommand}" ToolTip="Normalisieren" />
                        <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon ArrowSync24}" Content="Reverse" Command="{Binding ViewModel.ClipReverseCommand}" ToolTip="Umkehren" />
                        <ui:Button Margin="0,0,4,0" Icon="{ui:SymbolIcon MicSparkle24}" Content="Vocal-Cleanup" Command="{Binding ViewModel.ClipVocalCleanupCommand}"
                                   ToolTip="Glättet Vocals: De-Esser, Härte zähmen, sanfte Kompression" />
                        <ui:Button Icon="{ui:SymbolIcon Wand24}" Content="Variationen…" Click="ClipVariations_Click"
                                   ToolTip="Variationen-Provider auf diesen Clip anwenden" />
                    </WrapPanel>
                </StackPanel>

                <Border Width="1" Margin="16,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Stimme (ElevenLabs · nur Sprache)" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Icon="{ui:SymbolIcon PersonVoice24}" Content="Stimme tauschen"
                                   Command="{Binding ViewModel.ClipVoiceChangeCommand}"
                                   IsEnabled="{Binding ViewModel.IsVoiceChanging, Converter={StaticResource InverseBooleanConverter}}"
                                   ToolTip="Speech-to-Speech über ElevenLabs – nur für gesprochene Stimme (kein Gesang), nur eigene/lizenzierte Stimmen. Mit Auswahl wirkt es nur auf den markierten Bereich." />
                        <ui:ProgressRing Width="20" Height="20" Margin="8,0,0,0" IsIndeterminate="True"
                                         Visibility="{Binding ViewModel.IsVoiceChanging, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
        </StackPanel>

        <!-- Hinweis ohne Spuren (vollflächiges Drop-Ziel) -->
        <Border Grid.Row="2" Background="Transparent" AllowDrop="True"
                DragOver="Timeline_DragOver" Drop="Timeline_Drop"
                Visibility="{Binding ViewModel.HasTracks, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <ui:SymbolIcon Symbol="Layer24" FontSize="40" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <TextBlock Margin="0,12,0,0" HorizontalAlignment="Center" TextAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Noch keine Spuren.&#x0a;Audiodateien hierher ziehen, „Audio hinzufügen“ oder „Stems übernehmen“." />
        </StackPanel>
        </Border>

        <!-- Timeline (4-Quadranten: Ruler oben fixiert, Spurköpfe links fixiert) -->
        <Grid Grid.Row="2" Margin="0,14,0,0" AllowDrop="True"
              DragOver="Timeline_DragOver" Drop="Timeline_Drop"
              Visibility="{Binding ViewModel.HasTracks, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="28" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Ecke oben links -->
            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Bottom" Margin="2,0,0,4" FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Spuren" />

            <!-- Zeit-Lineal: oben fixiert, scrollt horizontal mit den Lanes -->
            <ScrollViewer x:Name="RulerScroll" Grid.Row="0" Grid.Column="1" Background="#FF15151B"
                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <controls:TimelineRulerControl
                    x:Name="Ruler" Cursor="IBeam"
                    MouseLeftButtonDown="Ruler_Down" MouseMove="Ruler_Move" MouseLeftButtonUp="Ruler_Up"
                    PixelsPerSecond="{Binding ViewModel.PixelsPerSecond}"
                    DurationSeconds="{Binding ViewModel.DurationSeconds}" />
            </ScrollViewer>

            <!-- Spurköpfe: links fixiert, scrollen vertikal mit den Lanes -->
            <ScrollViewer x:Name="HeaderScroll" Grid.Row="1" Grid.Column="0"
                          VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding ViewModel.Tracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="104" Margin="0,0,6,4" CornerRadius="8"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}">
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Stems trennen → automatisch (erkennen + beste Qualität)"
                                                  Command="{Binding ViewModel.SeparateTrackAutoCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Stems trennen → 4 (schnell)"
                                                  Command="{Binding ViewModel.SeparateTrackCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <Separator />
                                        <MenuItem Header="Spur löschen"
                                                  Command="{Binding ViewModel.DeleteTrackCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="8,0,0,8"
                                            Background="{Binding AccentColor, Converter={StaticResource StringToBrushConverter}}" />
                                    <Grid Grid.Column="1" Margin="8,6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Name (editierbar) + Aktiv + Löschen -->
                                        <DockPanel Grid.Row="0" LastChildFill="True">
                                            <CheckBox DockPanel.Dock="Left" Margin="0,0,4,0" VerticalAlignment="Center"
                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}" ToolTip="Spur aktiv" />
                                            <Button DockPanel.Dock="Right" Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.ViewModel.DeleteTrackCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}" ToolTip="Spur löschen">
                                                <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                                            </Button>
                                            <TextBox VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"
                                                     Background="Transparent" BorderThickness="0" Padding="0"
                                                     Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     ToolTip="Spur umbenennen" />
                                        </DockPanel>

                                        <Slider Grid.Row="1" Margin="0,2,0,0" Minimum="0" Maximum="1.5"
                                                Value="{Binding Volume, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" ToolTip="Lautstärke" />
                                        <Slider Grid.Row="2" Minimum="-1" Maximum="1"
                                                Value="{Binding Pan, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" ToolTip="Panorama" />

                                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,2,0,0">
                                            <ToggleButton Width="32" Height="24" Padding="0" Content="M" IsChecked="{Binding IsMuted, Mode=TwoWay}" ToolTip="Mute" />
                                            <ToggleButton Width="32" Height="24" Padding="0" Margin="6,0,0,0" Content="S" IsChecked="{Binding IsSolo, Mode=TwoWay}" ToolTip="Solo" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Lanes: scrollen horizontal + vertikal und treiben die Synchronisation -->
            <ScrollViewer x:Name="LaneScroll" Grid.Row="1" Grid.Column="1" Background="#FF15151B"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          ScrollChanged="Lane_ScrollChanged">
                    <Grid x:Name="LanesArea" Background="Transparent"
                          Width="{Binding ViewModel.ContentWidth}"
                          MouseLeftButtonDown="Lanes_MouseDown"
                          MouseMove="Lanes_MouseMove"
                          MouseLeftButtonUp="Lanes_MouseUp">
                        <controls:TimelineGridControl
                            PixelsPerSecond="{Binding ViewModel.PixelsPerSecond}"
                            GridSeconds="{Binding ViewModel.GridSeconds}"
                            IsHitTestVisible="False"
                            Visibility="{Binding ViewModel.SnapEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding ViewModel.Tracks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Spurzeile in voller Timeline-Breite; Clips werden per Margin positioniert -->
                                    <Grid Height="108"
                                          Width="{Binding DataContext.ViewModel.ContentWidth, RelativeSource={RelativeSource AncestorType=Page}}">
                                        <ItemsControl ItemsSource="{Binding Clips}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><Grid /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="ClipBox" Height="100" VerticalAlignment="Center" HorizontalAlignment="Left"
                                                            CornerRadius="8" ClipToBounds="True" Cursor="SizeWE"
                                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                            BorderThickness="2"
                                                            BorderBrush="{Binding AccentColor, Converter={StaticResource StringToBrushConverter}}"
                                                            MouseLeftButtonDown="Clip_Down" MouseMove="Clip_Move" MouseLeftButtonUp="Clip_Up"
                                                            MouseRightButtonDown="Clip_RightDown"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            ToolTip="Ziehen zum Verschieben · Klick zum Auswählen · Rechtsklick für Aktionen">
                                                        <Border.ContextMenu>
                                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                                <MenuItem Header="Vocal-Cleanup" Command="{Binding ViewModel.ClipVocalCleanupCommand}" />
                                                                <MenuItem Header="Hall" Command="{Binding ViewModel.ClipReverbCommand}" />
                                                                <MenuItem Header="Echo" Command="{Binding ViewModel.ClipEchoCommand}" />
                                                                <MenuItem Header="Normalisieren" Command="{Binding ViewModel.ClipNormalizeCommand}" />
                                                                <MenuItem Header="Umkehren (Reverse)" Command="{Binding ViewModel.ClipReverseCommand}" />
                                                                <MenuItem Header="Stimme tauschen (ElevenLabs · Sprache)" Command="{Binding ViewModel.ClipVoiceChangeCommand}" />
                                                                <MenuItem Header="Variationen…" Click="ClipVariations_Click" />
                                                                <Separator />
                                                                <MenuItem Header="Markierten Bereich ausschneiden" Command="{Binding ViewModel.CutRegionCommand}" />
                                                                <MenuItem Header="Am Playhead teilen" Command="{Binding ViewModel.SplitAtPlayheadCommand}" />
                                                                <MenuItem Header="Clip löschen" Command="{Binding ViewModel.DeleteSelectedCommand}" />
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <Border.Margin>
                                                            <MultiBinding Converter="{StaticResource SecondsToMarginConverter}">
                                                                <Binding Path="TimelineOffsetSeconds" />
                                                                <Binding Path="DataContext.ViewModel.PixelsPerSecond" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                            </MultiBinding>
                                                        </Border.Margin>
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource SecondsToWidthConverter}">
                                                                <Binding Path="LengthSeconds" />
                                                                <Binding Path="DataContext.ViewModel.PixelsPerSecond" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                            </MultiBinding>
                                                        </Border.Width>
                                                        <controls:WaveformControl
                                                            Margin="0,2" Peaks="{Binding Peaks}"
                                                            WaveBrush="{Binding AccentColor, Converter={StaticResource StringToBrushConverter}}" />
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter TargetName="ClipBox" Property="BorderBrush" Value="White" />
                                                            <Setter TargetName="ClipBox" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Spur-eigener Auswahlbereich (nur auf dieser Spur sichtbar) -->
                                        <Rectangle HorizontalAlignment="Left" VerticalAlignment="Stretch" IsHitTestVisible="False"
                                                   Fill="#403FA9FF" Stroke="White" StrokeThickness="1" StrokeDashArray="3 2"
                                                   Visibility="{Binding IsSelectionTrack, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Rectangle.Margin>
                                                <MultiBinding Converter="{StaticResource SecondsToMarginConverter}">
                                                    <Binding Path="DataContext.ViewModel.SelectionStartSeconds" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                    <Binding Path="DataContext.ViewModel.PixelsPerSecond" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                </MultiBinding>
                                            </Rectangle.Margin>
                                            <Rectangle.Width>
                                                <MultiBinding Converter="{StaticResource SecondsToWidthConverter}">
                                                    <Binding Path="DataContext.ViewModel.SelectionLengthSeconds" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                    <Binding Path="DataContext.ViewModel.PixelsPerSecond" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                </MultiBinding>
                                            </Rectangle.Width>
                                        </Rectangle>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Globaler Auswahlbereich (vom Zeit-Lineal, über alle Spuren) -->
                        <Rectangle HorizontalAlignment="Left" VerticalAlignment="Stretch" IsHitTestVisible="False"
                                   Fill="#305B8CFF" Stroke="#805B8CFF" StrokeThickness="1"
                                   Visibility="{Binding ViewModel.HasGlobalSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Rectangle.Margin>
                                <MultiBinding Converter="{StaticResource SecondsToMarginConverter}">
                                    <Binding Path="ViewModel.SelectionStartSeconds" />
                                    <Binding Path="ViewModel.PixelsPerSecond" />
                                </MultiBinding>
                            </Rectangle.Margin>
                            <Rectangle.Width>
                                <MultiBinding Converter="{StaticResource SecondsToWidthConverter}">
                                    <Binding Path="ViewModel.SelectionLengthSeconds" />
                                    <Binding Path="ViewModel.PixelsPerSecond" />
                                </MultiBinding>
                            </Rectangle.Width>
                        </Rectangle>

                        <!-- Playhead -->
                        <Rectangle Width="2" Fill="#FFFF5B5B" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                   Margin="{Binding ViewModel.PlayheadMargin}" IsHitTestVisible="False" />
                    </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Mixer-Panel (einblendbar) -->
        <Border Grid.Row="3" Margin="0,10,0,0" Padding="10,8" CornerRadius="10" Background="#FF15151B"
                Visibility="{Binding ViewModel.ShowMixer, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding ViewModel.Tracks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="80" Margin="0,0,6,0" CornerRadius="6"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                <Grid Margin="6,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="5" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" CornerRadius="3" Margin="0,0,0,4"
                                            Background="{Binding AccentColor, Converter={StaticResource StringToBrushConverter}}" />
                                    <TextBlock Grid.Row="1" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" Text="{Binding Name}" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4">
                                        <Slider Orientation="Vertical" Minimum="0" Maximum="1.5" Height="130"
                                                Value="{Binding Volume, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" ToolTip="Lautstärke" />
                                        <ProgressBar Orientation="Vertical" Minimum="0" Maximum="1" Width="7" Height="130" Margin="5,0,0,0"
                                                     Value="{Binding Level}" Foreground="#54D6A0" Background="#22FFFFFF" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <ToggleButton Width="28" Height="22" Padding="0" FontSize="10" Content="M" IsChecked="{Binding IsMuted, Mode=TwoWay}" ToolTip="Mute" />
                                        <ToggleButton Width="28" Height="22" Padding="0" FontSize="10" Margin="4,0,0,0" Content="S" IsChecked="{Binding IsSolo, Mode=TwoWay}" ToolTip="Solo" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
