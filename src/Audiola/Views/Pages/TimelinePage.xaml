<Page
    x:Class="Audiola.Views.Pages.TimelinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:Audiola.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Title="TimelinePage">

    <Page.InputBindings>
        <KeyBinding Modifiers="Control" Key="Z" Command="{Binding ViewModel.UndoCommand}" />
        <KeyBinding Modifiers="Control" Key="Y" Command="{Binding ViewModel.RedoCommand}" />
    </Page.InputBindings>

    <Page.Resources>
        <Style x:Key="ToolGroup" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,3,8,5" />
            <Setter Property="Margin" Value="0,0,8,6" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        </Style>
        <Style x:Key="ToolGroupCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="2,0,0,3" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="ToolBtn" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
    </Page.Resources>

    <Grid Margin="42,24,42,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Kopf + Mix-Export (oben rechts, auf Höhe des Titels) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource DawPageTitle}" Text="Studio" />
                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Mehrspur-Arbeitsfläche — Audiodateien hierher ziehen, Stems übernehmen, Clips schneiden &amp; mischen." />
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Top" Orientation="Horizontal">
                <ui:Button Margin="0,0,8,0" Icon="{ui:SymbolIcon Mic24}" Content="Einsingen"
                           Command="{Binding ViewModel.OpenSingAlongCommand}"
                           IsEnabled="{Binding ViewModel.HasTracks}"
                           ToolTip="Zum Song einsingen (Karaoke, Ton-Feedback) und als neue Spur übernehmen" />
                <ui:Button Appearance="Primary"
                           Icon="{ui:SymbolIcon ArrowExportLtr24}" Content="Mix exportieren"
                           Command="{Binding ViewModel.ExportMixCommand}"
                           IsEnabled="{Binding ViewModel.HasTracks}"
                           ToolTip="Den aktuellen Studio-Mix als Audiodatei speichern (WAV/MP3/…)" />
            </StackPanel>
        </Grid>

        <!-- Werkzeugleiste + Clip-Inspektor -->
        <StackPanel Grid.Row="1">
        <Border Margin="0,14,0,0" Padding="8,6" CornerRadius="10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <WrapPanel Orientation="Horizontal">

                <!-- Spuren -->
                <Border Style="{StaticResource ToolGroup}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolGroupCaption}" Text="SPUREN" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Style="{StaticResource ToolBtn}" Appearance="Primary" Icon="{ui:SymbolIcon Add24}"
                                       Command="{Binding ViewModel.AddAudioCommand}" ToolTip="Audiodatei als Spur hinzufügen" />
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon AddSquare24}"
                                       Command="{Binding ViewModel.AddEmptyTrackCommand}" ToolTip="Leere Spur anlegen (Parts dorthin verschieben)" />
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon Layer24}"
                                       Command="{Binding ViewModel.ImportStemsCommand}" ToolTip="Aktuelle Stems als Spuren übernehmen" />
                            <ui:Button Icon="{ui:SymbolIcon TextField24}" Click="AddTts_Click"
                                       ToolTip="Spur aus Text erzeugen (Sprache – Stimme im Dialog wählen: lokal oder ElevenLabs)" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Verlauf -->
                <Border Style="{StaticResource ToolGroup}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolGroupCaption}" Text="VERLAUF" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon ArrowUndo24}"
                                       Command="{Binding ViewModel.UndoCommand}" ToolTip="Rückgängig (Strg+Z)" />
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon ArrowRedo24}"
                                       Command="{Binding ViewModel.RedoCommand}" ToolTip="Wiederholen (Strg+Y)" />
                            <ToggleButton x:Name="HistoryToggle" Padding="8,0" VerticalAlignment="Center"
                                          IsChecked="{Binding ViewModel.ShowHistory, Mode=TwoWay}" ToolTip="Verlauf anzeigen">
                                <ui:SymbolIcon Symbol="History24" />
                            </ToggleButton>
                            <Popup PlacementTarget="{Binding ElementName=HistoryToggle}" Placement="Bottom" StaysOpen="False"
                                   IsOpen="{Binding ViewModel.ShowHistory, Mode=TwoWay}" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Margin="0,4,0,0" Width="320" MaxHeight="360" CornerRadius="8" Padding="6"
                                        Background="{DynamicResource ApplicationBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Margin="6,4,6,6" FontWeight="SemiBold"
                                                   Text="Verlauf — Klick springt zum Stand" />
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding ViewModel.History}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                Margin="0,1" Padding="8,5" BorderThickness="0" Background="Transparent"
                                                                Command="{Binding DataContext.ViewModel.JumpToHistoryCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                CommandParameter="{Binding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <ui:SymbolIcon Symbol="Circle24" FontSize="10" VerticalAlignment="Center"
                                                                               Visibility="{Binding IsCurrent, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                               Foreground="{DynamicResource DawAccentBrush}" Margin="0,0,8,0" />
                                                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsUndone}" Value="True">
                                                                            <Setter Property="Opacity" Value="0.45" />
                                                                            <Setter Property="FontStyle" Value="Italic" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Wiedergabe -->
                <Border Style="{StaticResource ToolGroup}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolGroupCaption}" Text="WIEDERGABE" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon Play24}" Command="{Binding ViewModel.PlayPauseCommand}" ToolTip="Abspielen / Pause" />
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon Stop24}" Command="{Binding ViewModel.StopCommand}" ToolTip="Stopp" />
                            <ui:ToggleSwitch VerticalAlignment="Center" IsChecked="{Binding ViewModel.LoopEnabled, Mode=TwoWay}" ToolTip="Auswahl loopen" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Bearbeiten -->
                <Border Style="{StaticResource ToolGroup}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolGroupCaption}" Text="BEARBEITEN" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon Cut24}" Command="{Binding ViewModel.SplitAtPlayheadCommand}" ToolTip="Clip am Playhead teilen" />
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon EraserSegment24}" Command="{Binding ViewModel.CutRegionCommand}" ToolTip="Markierten Bereich aus dem Clip herausschneiden" />
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon Delete24}" Command="{Binding ViewModel.DeleteSelectedCommand}" ToolTip="Clip löschen" />
                            <ui:ToggleSwitch VerticalAlignment="Center" Content="Bereich"
                                             IsChecked="{Binding ViewModel.RangeSelectMode, Mode=TwoWay}"
                                             ToolTip="Auswahl-Werkzeug: in den Spuren ziehen, um einen Bereich zu markieren (Effekte/Cleanup wirken dann nur darauf)" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Ansicht -->
                <Border Style="{StaticResource ToolGroup}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolGroupCaption}" Text="ANSICHT" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon ZoomOut24}" Command="{Binding ViewModel.ZoomOutCommand}" ToolTip="Auszoomen" />
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon ZoomIn24}" Command="{Binding ViewModel.ZoomInCommand}" ToolTip="Einzoomen" />
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon ZoomFit24}" Click="Fit_Click" ToolTip="Auf Song einpassen (ganzer Song sichtbar)" />
                            <ui:SymbolIcon Symbol="AutoFitHeight24" VerticalAlignment="Center" Margin="2,0,0,0"
                                           Foreground="{DynamicResource DawTextDimBrush}" />
                            <Slider Width="80" Margin="4,0,0,0" VerticalAlignment="Center" Minimum="80" Maximum="320"
                                    Value="{Binding ViewModel.LaneHeight, Mode=TwoWay}" ToolTip="Spurhöhe (Wellenform größer)" />
                            <ui:ToggleSwitch Margin="6,0,0,0" VerticalAlignment="Center" IsChecked="{Binding ViewModel.SnapEnabled, Mode=TwoWay}" ToolTip="Einrasten" />
                            <ComboBox Width="64" Margin="6,0,0,0" VerticalAlignment="Center"
                                      ItemsSource="{Binding ViewModel.GridOptions}" SelectedItem="{Binding ViewModel.GridSeconds, Mode=TwoWay}"
                                      ToolTip="Rasterweite (s)" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Auswahl -->
                <Border Style="{StaticResource ToolGroup}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolGroupCaption}" Text="AUSWAHL" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon SelectObjectSkew24}" Command="{Binding ViewModel.ClearSelectionCommand}" ToolTip="Auswahl löschen" />
                            <ui:Button Icon="{ui:SymbolIcon Save24}" Command="{Binding ViewModel.ExportRangeCommand}" ToolTip="Auswahlbereich exportieren" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Effekte & Ansicht -->
                <Border Style="{StaticResource ToolGroup}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ToolGroupCaption}" Text="EFFEKTE" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Style="{StaticResource ToolBtn}" Icon="{ui:SymbolIcon Wand24}" Content="Variationen" Click="Variations_All_Click"
                                       ToolTip="Variationen-Provider auf das gesamte Audio (alle Spuren) anwenden" />
                            <ui:ToggleSwitch VerticalAlignment="Center" Content="Mixer" IsChecked="{Binding ViewModel.ShowMixer, Mode=TwoWay}" ToolTip="Mixer-Panel ein-/ausblenden" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:ProgressRing Width="20" Height="20" Margin="6,0,0,0" VerticalAlignment="Center" IsIndeterminate="True"
                                     Visibility="{Binding ViewModel.IsSeparating, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock VerticalAlignment="Center" Margin="6,0,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding ViewModel.SeparationStatus}"
                               Visibility="{Binding ViewModel.IsSeparating, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Clip-Inspektor (bei Auswahl) -->
        <Border Margin="0,8,0,0" Padding="12,8" CornerRadius="10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                Visibility="{Binding ViewModel.HasSelectedClip, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Options24" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Clip" />
                <StackPanel Margin="20,0,0,0" Width="160">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="{Binding ViewModel.SelectedClip.GainDb, StringFormat='Lautstärke: {0:+0.0;-0.0;0} dB'}" />
                    <Slider Minimum="-24" Maximum="6" Value="{Binding ViewModel.SelectedClip.GainDb, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Margin="16,0,0,0" Width="150">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="{Binding ViewModel.SelectedClip.FadeInSeconds, StringFormat='Fade-In: {0:F2} s'}" />
                    <Slider Minimum="0" Maximum="5" Value="{Binding ViewModel.SelectedClip.FadeInSeconds, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Margin="16,0,0,0" Width="150">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="{Binding ViewModel.SelectedClip.FadeOutSeconds, StringFormat='Fade-Out: {0:F2} s'}" />
                    <Slider Minimum="0" Maximum="5" Value="{Binding ViewModel.SelectedClip.FadeOutSeconds, Mode=TwoWay}" />
                </StackPanel>

                <Border Width="1" Margin="16,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding ViewModel.ClipEffectScope}" Margin="0,0,0,4" />
                    <ui:Button Icon="{ui:SymbolIcon Wand24}" Content="Variationen / Effekte…" Click="ClipVariations_Click"
                               ToolTip="Provider + Variationen wählen (Hall, Echo, Cleanup … – auf den markierten Bereich oder den ganzen Clip)" />
                </StackPanel>

                <Border Width="1" Margin="16,2" Background="{DynamicResource CardStrokeColorDefaultBrush}" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Stimme" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Icon="{ui:SymbolIcon PersonVoice24}" Content="Stimme tauschen"
                                   Click="ClipVoiceChange_Click"
                                   IsEnabled="{Binding ViewModel.IsVoiceChanging, Converter={StaticResource InverseBooleanConverter}}"
                                   ToolTip="Speech-to-Speech – Zielstimme im Dialog wählen (lokal oder ElevenLabs), aufnehmen oder hochladen. Performance/Timing/Betonung (auch Gesang) bleiben erhalten, die Klangfarbe wird ersetzt. Am besten auf einer isolierten Vocal-Spur. Mit Auswahl wirkt es nur auf den markierten Bereich." />
                        <ui:ProgressRing Width="20" Height="20" Margin="8,0,0,0" IsIndeterminate="True"
                                         Visibility="{Binding ViewModel.IsVoiceChanging, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
        </StackPanel>

        <!-- Hinweis ohne Spuren (vollflächiges Drop-Ziel) -->
        <Border Grid.Row="2" Background="Transparent" AllowDrop="True"
                DragOver="Timeline_DragOver" Drop="Timeline_Drop"
                Visibility="{Binding ViewModel.HasTracks, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border MaxWidth="520" Padding="44,36" VerticalAlignment="Center" HorizontalAlignment="Center"
                    CornerRadius="14" BorderThickness="2" BorderBrush="{DynamicResource DawStrokeStrongBrush}"
                    Background="{DynamicResource DawPanelBrush}">
                <StackPanel>
                    <Rectangle Height="3" Width="72" RadiusX="1.5" RadiusY="1.5" HorizontalAlignment="Center"
                               Fill="{StaticResource BrandGradient}" />
                    <ui:SymbolIcon Symbol="MusicNote224" FontSize="42" Margin="0,18,0,0" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource DawTextDimBrush}" />
                    <TextBlock Margin="0,14,0,0" HorizontalAlignment="Center" FontSize="17" FontWeight="SemiBold"
                               Text="Song hierher ziehen" />
                    <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" TextAlignment="Center" FontSize="12.5"
                               Foreground="{DynamicResource DawTextFaintBrush}"
                               Text="Audio, mehrere Dateien oder ein ZIP — jede Datei wird eine Spur.&#x0a;Danach: Stems trennen, einsingen, mastern, exportieren." />
                    <ui:Button Margin="0,18,0,0" HorizontalAlignment="Center" Appearance="Primary"
                               Icon="{ui:SymbolIcon FolderOpen24}" Content="Datei öffnen…"
                               Command="{Binding ViewModel.AddAudioCommand}" />
                </StackPanel>
            </Border>
        </Border>

        <!-- Timeline (4-Quadranten: Ruler oben fixiert, Spurköpfe links fixiert) -->
        <Grid Grid.Row="2" Margin="0,14,0,0" AllowDrop="True"
              DragOver="Timeline_DragOver" Drop="Timeline_Drop"
              Visibility="{Binding ViewModel.HasTracks, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="28" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Ecke oben links -->
            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Bottom" Margin="2,0,0,4" FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Spuren" />

            <!-- Zeit-Lineal: oben fixiert, scrollt horizontal mit den Lanes -->
            <ScrollViewer x:Name="RulerScroll" Grid.Row="0" Grid.Column="1" Background="{DynamicResource DawTimelineBrush}"
                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <Grid>
                    <controls:TimelineRulerControl
                        x:Name="Ruler" Cursor="IBeam"
                        MouseLeftButtonDown="Ruler_Down" MouseMove="Ruler_Move" MouseLeftButtonUp="Ruler_Up"
                        PixelsPerSecond="{Binding ViewModel.PixelsPerSecond}"
                        DurationSeconds="{Binding ViewModel.DurationSeconds}" />
                    <!-- Ziehbarer Playhead-Griff -->
                    <Border Width="14" Height="20" VerticalAlignment="Top" HorizontalAlignment="Left"
                            Margin="{Binding ViewModel.PlayheadMargin}" Background="#FFFF5B5B"
                            CornerRadius="3" Cursor="SizeWE" ToolTip="Abspielposition ziehen"
                            MouseLeftButtonDown="Playhead_Down" MouseMove="Playhead_Move" MouseLeftButtonUp="Playhead_Up">
                        <Border.RenderTransform><TranslateTransform X="-7" /></Border.RenderTransform>
                        <Path Data="M 4,6 L 10,6 L 7,12 Z" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- Spurköpfe: links fixiert, scrollen vertikal mit den Lanes -->
            <ScrollViewer x:Name="HeaderScroll" Grid.Row="1" Grid.Column="0"
                          VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding ViewModel.Tracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="{Binding DataContext.ViewModel.LaneHeight, RelativeSource={RelativeSource AncestorType=Page}}"
                                    Margin="0,0,6,0" CornerRadius="8" BorderThickness="2"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    PreviewMouseLeftButtonDown="TrackHeader_Down"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectedTrack}" Value="True">
                                                <Setter Property="BorderBrush" Value="#5B8CFF" />
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#5B8CFF" BlurRadius="14" ShadowDepth="0" Opacity="0.8" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Stems trennen → automatisch (erkennen + beste Qualität)"
                                                  Command="{Binding ViewModel.SeparateTrackAutoCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Stems trennen → 4 (schnell)"
                                                  Command="{Binding ViewModel.SeparateTrackCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Trennen (HQ · audio-separator)">
                                            <MenuItem Header="RoFormer (Vocals / Instrumental)" Tag="roformer" Click="SeparateHq_Click" />
                                            <MenuItem Header="Demucs 6 Stems (Gitarre / Klavier)" Tag="demucs6s" Click="SeparateHq_Click" />
                                            <MenuItem Header="Karaoke (Lead / Background)" Tag="karaoke" Click="SeparateHq_Click" />
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="Spur duplizieren"
                                                  Command="{Binding ViewModel.DuplicateTrackCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Farbe">
                                            <MenuItem Header="Blau" Tag="#5B8CFF" Click="TrackColor_Click">
                                                <MenuItem.Icon><Border Width="14" Height="14" CornerRadius="3" Background="#5B8CFF" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Rot" Tag="#FF6B6B" Click="TrackColor_Click">
                                                <MenuItem.Icon><Border Width="14" Height="14" CornerRadius="3" Background="#FF6B6B" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Orange" Tag="#FFB454" Click="TrackColor_Click">
                                                <MenuItem.Icon><Border Width="14" Height="14" CornerRadius="3" Background="#FFB454" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Grün" Tag="#54D6A0" Click="TrackColor_Click">
                                                <MenuItem.Icon><Border Width="14" Height="14" CornerRadius="3" Background="#54D6A0" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Violett" Tag="#9B8CFF" Click="TrackColor_Click">
                                                <MenuItem.Icon><Border Width="14" Height="14" CornerRadius="3" Background="#9B8CFF" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Pink" Tag="#FF8AD8" Click="TrackColor_Click">
                                                <MenuItem.Icon><Border Width="14" Height="14" CornerRadius="3" Background="#FF8AD8" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Cyan" Tag="#6BD6FF" Click="TrackColor_Click">
                                                <MenuItem.Icon><Border Width="14" Height="14" CornerRadius="3" Background="#6BD6FF" /></MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Gelb" Tag="#D6C054" Click="TrackColor_Click">
                                                <MenuItem.Icon><Border Width="14" Height="14" CornerRadius="3" Background="#D6C054" /></MenuItem.Icon>
                                            </MenuItem>
                                        </MenuItem>
                                        <MenuItem Header="Spur mastern…"
                                                  Command="{Binding ViewModel.MasterTrackCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Spur exportieren…"
                                                  Command="{Binding ViewModel.ExportTrackCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="Spur löschen"
                                                  Command="{Binding ViewModel.DeleteTrackCommand}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="8,0,0,8"
                                            Background="{Binding AccentColor, Converter={StaticResource StringToBrushConverter}}" />
                                    <Grid Grid.Column="1" Margin="8,6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Name (editierbar) + Aktiv + Löschen -->
                                        <DockPanel Grid.Row="0" LastChildFill="True">
                                            <CheckBox DockPanel.Dock="Left" Margin="0,0,4,0" VerticalAlignment="Center"
                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}" ToolTip="Spur aktiv" />
                                            <Button DockPanel.Dock="Right" Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.ViewModel.DeleteTrackCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}" ToolTip="Spur löschen">
                                                <ui:SymbolIcon Symbol="Delete24" FontSize="14" />
                                            </Button>
                                            <Button DockPanel.Dock="Right" Width="24" Height="24" Padding="0" Margin="4,0,0,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Command="{Binding DataContext.ViewModel.ExportTrackCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}" ToolTip="Spur exportieren (WAV/MP3/…)">
                                                <ui:SymbolIcon Symbol="Save24" FontSize="14" />
                                            </Button>
                                            <TextBox VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13"
                                                     Background="Transparent" BorderThickness="0" Padding="0"
                                                     Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     ToolTip="Spur umbenennen" />
                                        </DockPanel>

                                        <Slider Grid.Row="1" Margin="0,2,0,0" Minimum="0" Maximum="1.5"
                                                Value="{Binding Volume, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" ToolTip="Lautstärke" />

                                        <!-- Panorama + Mute/Solo in einer Zeile (spart Höhe, damit M/S nicht abschneidet) -->
                                        <DockPanel Grid.Row="2" Margin="0,2,0,0" LastChildFill="True">
                                            <ToggleButton DockPanel.Dock="Right" Width="30" Height="24" Padding="0" Margin="6,0,0,0"
                                                          Content="S" IsChecked="{Binding IsSolo, Mode=TwoWay}" ToolTip="Solo" />
                                            <ToggleButton DockPanel.Dock="Right" Width="30" Height="24" Padding="0" Margin="8,0,0,0"
                                                          Content="M" IsChecked="{Binding IsMuted, Mode=TwoWay}" ToolTip="Mute" />
                                            <Slider VerticalAlignment="Center" Minimum="-1" Maximum="1"
                                                    Value="{Binding Pan, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" ToolTip="Panorama" />
                                        </DockPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Lanes: scrollen horizontal + vertikal und treiben die Synchronisation -->
            <ScrollViewer x:Name="LaneScroll" Grid.Row="1" Grid.Column="1" Background="{DynamicResource DawTimelineBrush}"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          ScrollChanged="Lane_ScrollChanged" PreviewMouseWheel="Lane_MouseWheel">
                    <Grid x:Name="LanesArea" Background="Transparent"
                          Width="{Binding ViewModel.ContentWidth}"
                          MouseLeftButtonDown="Lanes_MouseDown"
                          MouseMove="Lanes_MouseMove"
                          MouseLeftButtonUp="Lanes_MouseUp">
                        <controls:TimelineGridControl
                            PixelsPerSecond="{Binding ViewModel.PixelsPerSecond}"
                            GridSeconds="{Binding ViewModel.GridSeconds}"
                            IsHitTestVisible="False"
                            Visibility="{Binding ViewModel.SnapEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding ViewModel.Tracks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Spurzeile in voller Timeline-Breite; Clips werden per Margin positioniert -->
                                    <Grid Height="{Binding DataContext.ViewModel.LaneHeight, RelativeSource={RelativeSource AncestorType=Page}}"
                                          Width="{Binding DataContext.ViewModel.ContentWidth, RelativeSource={RelativeSource AncestorType=Page}}">
                                        <!-- Hervorhebung der ausgewählten Spur -->
                                        <Border IsHitTestVisible="False" Background="#142A6CFF"
                                                BorderBrush="#5B8CFF" BorderThickness="3,0,0,0"
                                                Visibility="{Binding IsSelectedTrack, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ItemsControl ItemsSource="{Binding Clips}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><Grid /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="ClipBox" VerticalAlignment="Stretch" HorizontalAlignment="Left"
                                                            CornerRadius="8" ClipToBounds="True" Cursor="SizeWE"
                                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                            BorderThickness="2"
                                                            BorderBrush="{Binding AccentColor, Converter={StaticResource StringToBrushConverter}}"
                                                            MouseLeftButtonDown="Clip_Down" MouseMove="Clip_Move" MouseLeftButtonUp="Clip_Up"
                                                            MouseRightButtonDown="Clip_RightDown"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            ToolTip="Ziehen zum Verschieben · Klick zum Auswählen · Rechtsklick für Aktionen">
                                                        <Border.ContextMenu>
                                                            <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                                                <MenuItem Header="Variationen / Effekte…" Click="ClipVariations_Click" />
                                                                <MenuItem Header="Stimme tauschen…" Click="ClipVoiceChange_Click" />
                                                <MenuItem Header="Transkribieren (Lyrics → LRC)">
                                                    <MenuItem Header="Lokal (Whisper)" Click="Transcribe_Click" />
                                                    <MenuItem Header="ElevenLabs" Click="TranscribeEleven_Click" />
                                                </MenuItem>
                                                                <Separator />
                                                                <MenuItem Header="Markierten Bereich ausschneiden" Command="{Binding ViewModel.CutRegionCommand}" />
                                                                <MenuItem Header="Am Playhead teilen" Command="{Binding ViewModel.SplitAtPlayheadCommand}" />
                                                                <MenuItem Header="Clip löschen" Command="{Binding ViewModel.DeleteSelectedCommand}" />
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <Border.Margin>
                                                            <MultiBinding Converter="{StaticResource SecondsToMarginConverter}">
                                                                <Binding Path="TimelineOffsetSeconds" />
                                                                <Binding Path="DataContext.ViewModel.PixelsPerSecond" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                            </MultiBinding>
                                                        </Border.Margin>
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource SecondsToWidthConverter}">
                                                                <Binding Path="LengthSeconds" />
                                                                <Binding Path="DataContext.ViewModel.PixelsPerSecond" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                            </MultiBinding>
                                                        </Border.Width>
                                                        <Grid>
                                                            <controls:WaveformControl
                                                                Margin="0,2" Peaks="{Binding Peaks}"
                                                                WaveBrush="{Binding AccentColor, Converter={StaticResource StringToBrushConverter}}" />
                                                            <controls:ClipFadeOverlay IsHitTestVisible="False"
                                                                FadeInSeconds="{Binding FadeInSeconds}"
                                                                FadeOutSeconds="{Binding FadeOutSeconds}"
                                                                PixelsPerSecond="{Binding DataContext.ViewModel.PixelsPerSecond, RelativeSource={RelativeSource AncestorType=Page}}" />
                                                            <!-- Fade-Griffe: an der Kante nach unten ziehen = Ein-/Ausblenden -->
                                                            <Border Width="13" Height="13" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"
                                                                    CornerRadius="7" Background="#E6FFFFFF" Cursor="SizeNS" ToolTip="Fade-In: nach unten ziehen"
                                                                    MouseLeftButtonDown="FadeIn_Down" MouseMove="Fade_Move" MouseLeftButtonUp="Fade_Up" />
                                                            <Border Width="13" Height="13" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2"
                                                                    CornerRadius="7" Background="#E6FFFFFF" Cursor="SizeNS" ToolTip="Fade-Out: nach unten ziehen"
                                                                    MouseLeftButtonDown="FadeOut_Down" MouseMove="Fade_Move" MouseLeftButtonUp="Fade_Up" />
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter TargetName="ClipBox" Property="BorderBrush" Value="White" />
                                                            <Setter TargetName="ClipBox" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Spur-eigener Auswahlbereich (nur auf dieser Spur sichtbar) -->
                                        <Rectangle HorizontalAlignment="Left" VerticalAlignment="Stretch" IsHitTestVisible="False"
                                                   Fill="#403FA9FF" Stroke="White" StrokeThickness="1" StrokeDashArray="3 2"
                                                   Visibility="{Binding IsSelectionTrack, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Rectangle.Margin>
                                                <MultiBinding Converter="{StaticResource SecondsToMarginConverter}">
                                                    <Binding Path="DataContext.ViewModel.SelectionStartSeconds" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                    <Binding Path="DataContext.ViewModel.PixelsPerSecond" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                </MultiBinding>
                                            </Rectangle.Margin>
                                            <Rectangle.Width>
                                                <MultiBinding Converter="{StaticResource SecondsToWidthConverter}">
                                                    <Binding Path="DataContext.ViewModel.SelectionLengthSeconds" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                    <Binding Path="DataContext.ViewModel.PixelsPerSecond" RelativeSource="{RelativeSource AncestorType=Page}" />
                                                </MultiBinding>
                                            </Rectangle.Width>
                                        </Rectangle>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Globaler Auswahlbereich (vom Zeit-Lineal, über alle Spuren) -->
                        <Rectangle HorizontalAlignment="Left" VerticalAlignment="Stretch" IsHitTestVisible="False"
                                   Fill="#305B8CFF" Stroke="#805B8CFF" StrokeThickness="1"
                                   Visibility="{Binding ViewModel.HasGlobalSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Rectangle.Margin>
                                <MultiBinding Converter="{StaticResource SecondsToMarginConverter}">
                                    <Binding Path="ViewModel.SelectionStartSeconds" />
                                    <Binding Path="ViewModel.PixelsPerSecond" />
                                </MultiBinding>
                            </Rectangle.Margin>
                            <Rectangle.Width>
                                <MultiBinding Converter="{StaticResource SecondsToWidthConverter}">
                                    <Binding Path="ViewModel.SelectionLengthSeconds" />
                                    <Binding Path="ViewModel.PixelsPerSecond" />
                                </MultiBinding>
                            </Rectangle.Width>
                        </Rectangle>

                        <!-- Playhead -->
                        <Rectangle Width="2" Fill="#FFFF5B5B" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                   Margin="{Binding ViewModel.PlayheadMargin}" IsHitTestVisible="False" />
                    </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Mixer-Panel (einblendbar) -->
        <Border Grid.Row="3" Margin="0,10,0,0" Padding="10,8" CornerRadius="10" Background="{DynamicResource DawTimelineBrush}"
                Visibility="{Binding ViewModel.ShowMixer, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding ViewModel.Tracks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="80" Margin="0,0,6,0" CornerRadius="6"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                <Grid Margin="6,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="5" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" CornerRadius="3" Margin="0,0,0,4"
                                            Background="{Binding AccentColor, Converter={StaticResource StringToBrushConverter}}" />
                                    <TextBlock Grid.Row="1" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" Text="{Binding Name}" />
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4">
                                        <Slider Orientation="Vertical" Minimum="0" Maximum="1.5" Height="130"
                                                Value="{Binding Volume, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" ToolTip="Lautstärke" />
                                        <ProgressBar Orientation="Vertical" Minimum="0" Maximum="1" Width="7" Height="130" Margin="5,0,0,0"
                                                     Value="{Binding Level}" Foreground="#54D6A0" Background="#22FFFFFF" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <ToggleButton Width="28" Height="22" Padding="0" FontSize="10" Content="M" IsChecked="{Binding IsMuted, Mode=TwoWay}" ToolTip="Mute" />
                                        <ToggleButton Width="28" Height="22" Padding="0" FontSize="10" Margin="4,0,0,0" Content="S" IsChecked="{Binding IsSolo, Mode=TwoWay}" ToolTip="Solo" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
