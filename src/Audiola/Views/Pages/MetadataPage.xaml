<Page
    x:Class="Audiola.Views.Pages.MetadataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Title="MetadataPage">

    <Grid Margin="42,24,42,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Kopf -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource DawPageTitle}" Text="Metadaten" />
            <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Song-Tags für das Projekt — werden beim Öffnen gelesen, im Projekt gespeichert und bei jedem Export geschrieben." />
        </StackPanel>

        <!-- Aktionen -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,0">
            <ui:Button Icon="{ui:SymbolIcon DocumentArrowDown24}" Content="Tags aus Datei laden"
                       Command="{Binding ViewModel.ImportFromFileCommand}" />
            <ui:Button Margin="8,0,0,0" Appearance="Secondary" Icon="{ui:SymbolIcon Eraser24}" Content="Leeren"
                       Command="{Binding ViewModel.ClearCommand}" />
            <ui:ProgressRing Margin="16,0,0,0" Width="22" Height="22" VerticalAlignment="Center" IsIndeterminate="True"
                             Visibility="{Binding ViewModel.IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <ui:DynamicScrollViewer Grid.Row="2" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="820" HorizontalAlignment="Left">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Cover -->
                    <StackPanel Grid.Column="0" Width="180" Margin="0,0,20,0">
                        <Border Width="180" Height="180" CornerRadius="10" Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <Grid>
                                <ui:SymbolIcon Symbol="Image24" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Visibility="{Binding ViewModel.Meta.HasCover, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                <Image Stretch="UniformToFill"
                                       Source="{Binding ViewModel.Meta.CoverArt, Converter={StaticResource BytesToImageConverter}}" />
                            </Grid>
                        </Border>
                        <ui:Button Margin="0,10,0,0" HorizontalAlignment="Stretch" Icon="{ui:SymbolIcon Image24}"
                                   Content="Cover wählen" Command="{Binding ViewModel.ChooseCoverCommand}" />
                        <ui:Button Margin="0,6,0,0" HorizontalAlignment="Stretch" Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Delete24}" Content="Cover entfernen"
                                   Command="{Binding ViewModel.RemoveCoverCommand}"
                                   Visibility="{Binding ViewModel.Meta.HasCover, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <!-- Tag-Felder -->
                    <StackPanel Grid.Column="1">
                        <TextBlock FontWeight="SemiBold" Text="Titel" />
                        <ui:TextBox Margin="0,2,0,8" Text="{Binding ViewModel.Meta.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock FontWeight="SemiBold" Text="Interpret" />
                        <ui:TextBox Margin="0,2,0,8" Text="{Binding ViewModel.Meta.Artist, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock FontWeight="SemiBold" Text="Album" />
                        <ui:TextBox Margin="0,2,0,8" Text="{Binding ViewModel.Meta.Album, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock FontWeight="SemiBold" Text="Genre" />
                                <ui:TextBox Margin="0,2,0,8" Text="{Binding ViewModel.Meta.Genre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock FontWeight="SemiBold" Text="Jahr" />
                                <ui:TextBox Margin="0,2,0,8" Text="{Binding ViewModel.Meta.Year, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock FontWeight="SemiBold" Text="Track" />
                                <ui:TextBox Margin="0,2,0,8" Text="{Binding ViewModel.Meta.TrackNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock FontWeight="SemiBold" Text="Album-Interpret" />
                        <ui:TextBox Margin="0,2,0,8" Text="{Binding ViewModel.Meta.AlbumArtist, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock FontWeight="SemiBold" Text="Kommentar" />
                        <ui:TextBox Margin="0,2,0,8" Text="{Binding ViewModel.Meta.Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <!-- Lyrics -->
                <Border Margin="0,12,0,0" Padding="14" CornerRadius="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Text="Liedtext" />
                            <ui:Button Margin="16,0,0,0" Appearance="Secondary" Icon="{ui:SymbolIcon Wand24}"
                                       Content="Aus Mix erzeugen (Whisper)"
                                       Command="{Binding ViewModel.GenerateLyricsCommand}" />
                            <ui:Button Margin="8,0,0,0" Appearance="Secondary" Icon="{ui:SymbolIcon Cloud24}"
                                       Content="via ElevenLabs"
                                       Command="{Binding ViewModel.GenerateLyricsCommand}" CommandParameter="eleven"
                                       Visibility="{Binding ViewModel.ElevenLabsAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <ui:TextBox Margin="0,8,0,0" MinHeight="160" MaxHeight="340" AcceptsReturn="True" TextWrapping="Wrap"
                                    VerticalScrollBarVisibility="Auto"
                                    PlaceholderText="Liedtext — LRC mit Zeitstempeln [mm:ss.xx] wird unterstützt und beim Export sowohl als Tag als auch als .lrc-Datei geschrieben."
                                    Text="{Binding ViewModel.Meta.Lyrics, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="12"
                           TextWrapping="Wrap" Text="{Binding ViewModel.Status}" />
            </StackPanel>
        </ui:DynamicScrollViewer>
    </Grid>
</Page>
