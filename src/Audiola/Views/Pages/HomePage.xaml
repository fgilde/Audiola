<Page
    x:Class="Audiola.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Title="HomePage">

    <Page.Resources>
        <!-- Schnellstart-Karte: großer Klickbereich mit Icon, Titel, Untertitel.
             Foreground explizit: Custom-Templates ersetzen den WPF-UI-Style, sonst fiele
             die Textfarbe auf das WPF-Default-Schwarz zurück. -->
        <Style x:Key="QuickCard" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource DawTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Width="230" Padding="18,16" CornerRadius="12"
                                Background="{StaticResource DawPanelBrush}"
                                BorderBrush="{StaticResource DawStrokeBrush}" BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource DawCardBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource DawAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Listeneintrag (Projekt/Datei): ganze Zeile klickbar, Akzentkante links über Tag;
             fehlende Dateien werden gedimmt dargestellt. -->
        <Style x:Key="RecentCard" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource DawTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Padding="12,10" CornerRadius="10"
                                Background="{StaticResource DawPanelBrush}"
                                BorderBrush="Transparent" BorderThickness="3,0,0,0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource DawCardBrush}" />
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Fehlende Dateien gedimmt darstellen (Triggers müssen nach den Settern stehen). -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding Exists}" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Kleine Icon-Aktion (Entfernen/Löschen) am Zeilenende. -->
        <Style x:Key="RowAction" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Foreground" Value="{StaticResource DawTextFaintBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource DawHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource DawTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Dezenter Marken-Glow hinter dem Hero -->
        <Border Height="420" VerticalAlignment="Top" IsHitTestVisible="False">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.1" RadiusX="0.75" RadiusY="0.9">
                    <GradientStop Color="#2E3F8CFF" Offset="0" />
                    <GradientStop Color="#12B56BFF" Offset="0.55" />
                    <GradientStop Color="#00000000" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="1060" Margin="42,40,42,32" HorizontalAlignment="Center">

                <!-- ======= HERO ======= -->
                <Image Source="pack://application:,,,/Assets/audiola.png" Width="92" Height="92"
                       HorizontalAlignment="Center">
                    <Image.Effect>
                        <DropShadowEffect Color="#5B8CFF" BlurRadius="42" ShadowDepth="0" Opacity="0.55" />
                    </Image.Effect>
                </Image>
                <TextBlock Margin="0,14,0,0" HorizontalAlignment="Center" FontSize="40" FontWeight="Bold"
                           Text="Audiola" />
                <Rectangle Width="120" Height="3" Margin="0,10,0,0" RadiusX="1.5" RadiusY="1.5"
                           HorizontalAlignment="Center" Fill="{StaticResource BrandGradient}" />
                <TextBlock Margin="0,12,0,0" HorizontalAlignment="Center" FontSize="14"
                           Foreground="{StaticResource DawTextDimBrush}"
                           Text="Trennen · Mischen · Einsingen · Mastern — dein Studio für alles." />

                <!-- ======= SCHNELLSTART ======= -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,34,0,0">
                    <Button Style="{StaticResource QuickCard}" Command="{Binding ViewModel.OpenFileCommand}">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="MusicNote224" FontSize="26" Foreground="{StaticResource DawAccentLightBrush}" />
                            <TextBlock Margin="0,10,0,2" FontWeight="SemiBold" FontSize="15" Text="Song öffnen" />
                            <TextBlock FontSize="12" Foreground="{StaticResource DawTextFaintBrush}"
                                       Text="Audio laden — jede Datei wird eine Spur" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource QuickCard}" Command="{Binding ViewModel.OpenProjectDialogCommand}">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="26" Foreground="#B56BFF" />
                            <TextBlock Margin="0,10,0,2" FontWeight="SemiBold" FontSize="15" Text="Projekt öffnen" />
                            <TextBlock FontSize="12" Foreground="{StaticResource DawTextFaintBrush}"
                                       Text="Ein gespeichertes .audiola-Projekt fortsetzen" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource QuickCard}" Margin="0" Command="{Binding ViewModel.GoToStudioCommand}">
                        <StackPanel>
                            <ui:SymbolIcon Symbol="Timeline24" FontSize="26" Foreground="{StaticResource DawGreenBrush}" />
                            <TextBlock Margin="0,10,0,2" FontWeight="SemiBold" FontSize="15" Text="Zum Studio" />
                            <TextBlock FontSize="12" Foreground="{StaticResource DawTextFaintBrush}"
                                       Text="Direkt zur Mehrspur-Arbeitsfläche" TextWrapping="Wrap" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- ======= PROJEKTE | ZULETZT GEÖFFNET ======= -->
                <Grid Margin="0,40,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Projekte (violette Akzentkante) -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="15" Foreground="#B56BFF" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Style="{StaticResource DawCaption}" Text="PROJEKTE" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding ViewModel.RecentProjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RecentCard}" Tag="#B56BFF"
                                            Command="{Binding DataContext.ViewModel.OpenCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}" ToolTip="{Binding Path}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="34" Height="34" CornerRadius="8" Background="#26B56BFF">
                                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="16" Foreground="#B56BFF" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="11,0,8,0" VerticalAlignment="Center">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="11" Foreground="{StaticResource DawTextFaintBrush}"
                                                           Text="{Binding DetailsText}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource RowAction}" ToolTip="Aus der Liste entfernen"
                                                        Command="{Binding DataContext.ViewModel.RemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}">
                                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="13" />
                                                </Button>
                                                <Button Style="{StaticResource RowAction}" ToolTip="Datei löschen"
                                                        Command="{Binding DataContext.ViewModel.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}">
                                                    <ui:SymbolIcon Symbol="Delete24" FontSize="13" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock FontSize="12" Foreground="{StaticResource DawTextFaintBrush}" TextWrapping="Wrap"
                                   Text="Noch keine Projekte — speichere dein Studio über Datei → „Projekt speichern“ als .audiola."
                                   Visibility="{Binding ViewModel.HasRecentProjects, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <!-- Zuletzt geöffnete Dateien (blaue Akzentkante) -->
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:SymbolIcon Symbol="History24" FontSize="15" Foreground="{StaticResource DawAccentLightBrush}" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Style="{StaticResource DawCaption}" Text="ZULETZT GEÖFFNET" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding ViewModel.RecentFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RecentCard}" Tag="#3F8CFF"
                                            Command="{Binding DataContext.ViewModel.OpenCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}" ToolTip="{Binding Path}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="34" Height="34" CornerRadius="8" Background="#263F8CFF">
                                                <ui:SymbolIcon Symbol="MusicNote224" FontSize="16" Foreground="{StaticResource DawAccentLightBrush}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="11,0,8,0" VerticalAlignment="Center">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="11" Foreground="{StaticResource DawTextFaintBrush}"
                                                           Text="{Binding DetailsText}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource RowAction}" ToolTip="Aus der Liste entfernen"
                                                        Command="{Binding DataContext.ViewModel.RemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}">
                                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="13" />
                                                </Button>
                                                <Button Style="{StaticResource RowAction}" ToolTip="Datei löschen"
                                                        Command="{Binding DataContext.ViewModel.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}">
                                                    <ui:SymbolIcon Symbol="Delete24" FontSize="13" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock FontSize="12" Foreground="{StaticResource DawTextFaintBrush}" TextWrapping="Wrap"
                                   Text="Noch nichts geöffnet — zieh einfach eine Audiodatei oder ein ZIP ins Fenster."
                                   Visibility="{Binding ViewModel.HasRecent, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>

                <ui:ProgressRing Margin="0,26,0,0" HorizontalAlignment="Center" IsIndeterminate="True"
                                 Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
