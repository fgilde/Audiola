<Page
    x:Class="Audiola.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="HomePage"
    d:DataContext="{d:DesignInstance Type=local:HomePage}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Audiola.Views.Pages">

    <Page.Resources>
        <!-- Eintrag in einer Recent-Liste: Öffnen-Button + Entfernen/Löschen -->
        <DataTemplate x:Key="RecentItemTemplate">
            <Border Margin="0,0,0,8" Padding="4" CornerRadius="8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Padding="8,6" BorderThickness="0" Background="Transparent"
                            Command="{Binding DataContext.ViewModel.OpenCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                            CommandParameter="{Binding}" ToolTip="{Binding Path}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="{Binding IconSymbol}" FontSize="22" VerticalAlignment="Center" Margin="2,0,12,0" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Folder}" FontSize="11" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock Text="{Binding DetailsText}" FontSize="11" Margin="0,2,0,0"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,4,0">
                        <Button Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0"
                                Command="{Binding DataContext.ViewModel.RemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}" ToolTip="Aus Liste entfernen">
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="15" />
                        </Button>
                        <Button Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0"
                                Command="{Binding DataContext.ViewModel.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                CommandParameter="{Binding}" ToolTip="Datei von der Festplatte löschen">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="15" Foreground="#FF6B6B" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Margin="42,24,42,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Kopf -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock FontSize="26" FontWeight="SemiBold" Text="Willkommen bei Audiola" />
                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Audiodateien bearbeiten, in Stems trennen und neu mischen — oder eine Datei ins Fenster ziehen." />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:ProgressRing Margin="0,0,12,0" Width="22" Height="22" IsIndeterminate="True"
                                 Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon FolderOpen24}" Content="Audiodatei öffnen"
                           Command="{Binding ViewModel.OpenFileCommand}" />
            </StackPanel>
        </Grid>

        <!-- Zwei Spalten: Projekte links, Songs rechts -->
        <Grid Grid.Row="1" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Letzte Projekte -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <ui:SymbolIcon Symbol="FolderOpen24" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Letzte Projekte" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" Margin="2,0,0,8" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="Noch keine Projekte gespeichert."
                           Visibility="{Binding ViewModel.HasRecentProjects, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ViewModel.RecentProjects}" ItemTemplate="{StaticResource RecentItemTemplate}" />
                </ScrollViewer>
            </DockPanel>

            <!-- Letzte Songs / Dateien -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <ui:SymbolIcon Symbol="MusicNote224" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Zuletzt geöffnete Songs" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" Margin="2,0,0,8" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="Noch keine Dateien geöffnet."
                           Visibility="{Binding ViewModel.HasRecent, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ViewModel.RecentFiles}" ItemTemplate="{StaticResource RecentItemTemplate}" />
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Grid>
</Page>
