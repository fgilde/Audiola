<Page
    x:Class="Audiola.Views.Pages.VoicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Title="VoicesPage">

    <ScrollViewer Margin="42,24,42,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1120" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource DawPageTitle}" Text="Stimmen" />
            <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Lokale Modelle verwalten und eigene Stimmen erstellen (CUDA/CPU) — oder ElevenLabs nutzen. Stimmen werden projektübergreifend gespeichert." />

            <!-- Engine / Gerät -->
            <ui:Card Margin="0,16,0,0" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Settings24" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <TextBlock VerticalAlignment="Center" Text="Rechen-Gerät:" Margin="0,0,8,0" />
                        <ComboBox Width="140" VerticalAlignment="Center" ItemsSource="{Binding ViewModel.Devices}"
                                  SelectedItem="{Binding ViewModel.SelectedDevice, Mode=TwoWay}" />
                        <TextBlock VerticalAlignment="Center" Margin="24,0,8,0" Text="Whisper-Modell (Transkription):" />
                        <ComboBox Width="120" VerticalAlignment="Center" ItemsSource="{Binding ViewModel.WhisperModels}"
                                  SelectedItem="{Binding ViewModel.WhisperModel, Mode=TwoWay}" />
                        <ui:ProgressRing Width="20" Height="20" Margin="16,0,0,0" IsIndeterminate="True" VerticalAlignment="Center"
                                         Visibility="{Binding ViewModel.IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="{Binding ViewModel.Status}" />
                    </StackPanel>

                    <!-- GPU-Status / CUDA -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,12,0,0">
                        <ui:SymbolIcon Symbol="DeveloperBoard24" VerticalAlignment="Center" Margin="0,0,12,0" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding ViewModel.GpuStatus}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.CudaActive, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                            <Setter Property="Foreground" Value="#54D6A0" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ui:Button Margin="14,0,0,0" Icon="{ui:SymbolIcon ArrowSync24}" Content="GPU prüfen"
                                   Command="{Binding ViewModel.CheckGpuCommand}" />
                        <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon ArrowDownload24}" Content="CUDA-Torch installieren"
                                   Command="{Binding ViewModel.InstallCudaTorchCommand}" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Modelle -->
                <DockPanel Grid.Column="0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Modelle" VerticalAlignment="Center" />
                        <ui:Button Margin="12,0,0,0" Icon="{ui:SymbolIcon ArrowSync24}" Content="Aktualisieren"
                                   Command="{Binding ViewModel.LoadModelsCommand}" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding ViewModel.Models}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,0,0,8" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="4" Background="#2E7D32"
                                                        Visibility="{Binding Installed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="installiert" FontSize="10" Foreground="White" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBlock FontSize="11" Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Text="{Binding SizeText, StringFormat='≈ {0}'}" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" VerticalAlignment="Center" Icon="{ui:SymbolIcon ArrowDownload24}" Content="Laden"
                                                   Command="{Binding DataContext.ViewModel.DownloadModelCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}" />
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>

                <!-- Eigene Stimmen -->
                <DockPanel Grid.Column="2">
                    <TextBlock DockPanel.Dock="Top" FontSize="16" FontWeight="SemiBold" Text="Eigene Stimmen" Margin="0,0,0,10" />

                    <!-- Vorschau-Text (für ▶ je Stimme) -->
                    <ui:TextBox DockPanel.Dock="Top" Margin="0,0,0,10" PlaceholderText="Vorschau-Text"
                                Icon="{ui:SymbolIcon TextField24}"
                                Text="{Binding ViewModel.PreviewText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ui:Card DockPanel.Dock="Top" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Neue Stimme erstellen" Margin="0,0,0,8" />
                            <ui:TextBox PlaceholderText="Name" Text="{Binding ViewModel.NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <ComboBox Width="200" ItemsSource="{Binding ViewModel.Models}" DisplayMemberPath="Name"
                                          SelectedItem="{Binding ViewModel.NewModel, Mode=TwoWay}" />
                                <ui:TextBox Width="70" Margin="8,0,0,0" PlaceholderText="Sprache"
                                            Text="{Binding ViewModel.NewLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <ui:Button Content="Sample wählen…" Icon="{ui:SymbolIcon FolderOpen24}" Command="{Binding ViewModel.BrowseSampleCommand}" />
                                <ui:Button Margin="8,0,0,0" Command="{Binding ViewModel.ToggleRecordCommand}">
                                    <ui:Button.Style>
                                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                            <Setter Property="Content" Value="● Aufnehmen" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ViewModel.IsRecording, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                                    <Setter Property="Content" Value="■ Stopp" />
                                                    <Setter Property="Appearance" Value="Danger" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:Button.Style>
                                </ui:Button>
                                <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Text="{Binding ViewModel.SamplePath, TargetNullValue='kein Sample'}" />
                            </StackPanel>
                            <ui:Button Margin="0,10,0,0" Appearance="Primary" Icon="{ui:SymbolIcon Add24}" Content="Stimme erstellen"
                                       Command="{Binding ViewModel.CreateProfileCommand}" />
                        </StackPanel>
                    </ui:Card>

                    <ItemsControl ItemsSource="{Binding ViewModel.Profiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,0,0,8" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="{Binding Description}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:Button Icon="{ui:SymbolIcon Play24}"
                                                       Command="{Binding DataContext.ViewModel.PreviewProfileCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" ToolTip="Vorschau abspielen" />
                                            <ui:Button Margin="6,0,0,0" Icon="{ui:SymbolIcon Delete24}"
                                                       Command="{Binding DataContext.ViewModel.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" ToolTip="Stimme löschen" />
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Grid>

            <!-- Transkriptions-Modelle (Whisper) -->
            <StackPanel Orientation="Horizontal" Margin="0,22,0,10">
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Transkriptions-Modelle (Whisper)" VerticalAlignment="Center" />
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="{Binding ViewModel.WhisperModel, StringFormat='Aktiv: {0}'}" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding ViewModel.WhisperModelsList}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,8,8" Padding="12" Width="250">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="4" Background="#2E7D32"
                                                Visibility="{Binding Installed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="installiert" FontSize="10" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Text="{Binding SizeText, StringFormat='≈ {0}'}" />
                                </StackPanel>
                                <ui:Button Grid.Column="1" VerticalAlignment="Center" Icon="{ui:SymbolIcon ArrowDownload24}"
                                           Command="{Binding DataContext.ViewModel.DownloadModelCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}" ToolTip="Modell herunterladen" />
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
