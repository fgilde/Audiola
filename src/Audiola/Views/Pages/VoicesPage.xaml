<Page
    x:Class="Audiola.Views.Pages.VoicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:Audiola.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Title="VoicesPage">

    <Page.Resources>
        <!-- Grüner „installiert"-Badge (themebar) -->
        <Style x:Key="InstalledBadge" TargetType="Border">
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource DawGreenBrush}" />
        </Style>
        <Style x:Key="SectionCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource DawTextFaintBrush}" />
            <Setter Property="Margin" Value="2,0,0,8" />
        </Style>
    </Page.Resources>

    <ScrollViewer Margin="42,24,42,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1120" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource DawPageTitle}" Text="Stimmen" />
            <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="Eigene Stimmen erstellen und verwalten — lokal (CUDA/CPU) oder mit ElevenLabs. Stimmen gelten projektübergreifend." />

            <!-- ————— Engine-Leiste ————— -->
            <Border Margin="0,18,0,0" Padding="16,12" CornerRadius="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,26,0">
                        <TextBlock Style="{StaticResource SectionCaption}" Text="RECHEN-GERÄT" />
                        <ComboBox Width="130" ItemsSource="{Binding ViewModel.Devices}"
                                  SelectedItem="{Binding ViewModel.SelectedDevice, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,26,0">
                        <TextBlock Style="{StaticResource SectionCaption}" Text="WHISPER (TRANSKRIPTION)" />
                        <ComboBox Width="130" ItemsSource="{Binding ViewModel.WhisperModels}"
                                  SelectedItem="{Binding ViewModel.WhisperModel, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,16,3">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="14" VerticalAlignment="Center"
                                           Foreground="{DynamicResource DawTextDimBrush}" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                                       Text="{Binding ViewModel.GpuStatus}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ViewModel.CudaActive, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource DawGreenBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <ui:ProgressRing Width="16" Height="16" Margin="0,0,8,0" IsIndeterminate="True" VerticalAlignment="Center"
                                             Visibility="{Binding ViewModel.IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding ViewModel.Status}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <ui:Button Icon="{ui:SymbolIcon ArrowSync24}" Content="GPU prüfen"
                                   Command="{Binding ViewModel.CheckGpuCommand}" />
                        <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon ArrowDownload24}" Content="CUDA-Torch"
                                   ToolTip="PyTorch mit CUDA-Unterstützung installieren (GPU-Beschleunigung)"
                                   Command="{Binding ViewModel.InstallCudaTorchCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="5*" />
                </Grid.ColumnDefinitions>

                <!-- ————— LINKS: Eigene Stimme erstellen + Liste ————— -->
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionCaption}" Text="NEUE STIMME ERSTELLEN" />
                    <Border Padding="18" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <!-- 1 · Name / Modell / Sprache -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="64" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox Grid.Column="0" PlaceholderText="Name der Stimme" Icon="{ui:SymbolIcon Person24}"
                                            Text="{Binding ViewModel.NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox Grid.Column="2" ItemsSource="{Binding ViewModel.Models}" DisplayMemberPath="Name"
                                          SelectedItem="{Binding ViewModel.NewModel, Mode=TwoWay}" ToolTip="Voice-Modell" />
                                <ui:TextBox Grid.Column="4" PlaceholderText="de"
                                            Text="{Binding ViewModel.NewLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            ToolTip="Sprache (z. B. de, en)" />
                            </Grid>

                            <!-- 2 · Mikrofon (mit Live-Pegel) -->
                            <TextBlock Style="{StaticResource SectionCaption}" Margin="2,16,0,6"
                                       Text="MIKROFON — der Balken zeigt dein Signal" />
                            <controls:MicSelectorControl HorizontalAlignment="Left"
                                                         DeviceNumber="{Binding ViewModel.RecordDeviceNumber, Mode=TwoWay}" />

                            <!-- 3 · Aufnehmen oder Datei -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <ui:Button MinWidth="150" Command="{Binding ViewModel.ToggleRecordCommand}">
                                    <ui:Button.Style>
                                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                            <Setter Property="Content" Value="●  Aufnehmen" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ViewModel.IsRecording, RelativeSource={RelativeSource AncestorType=Page}}" Value="True">
                                                    <Setter Property="Content" Value="■  Stopp" />
                                                    <Setter Property="Appearance" Value="Danger" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:Button.Style>
                                </ui:Button>
                                <TextBlock VerticalAlignment="Center" Margin="12,0" FontSize="12"
                                           Foreground="{DynamicResource DawTextFaintBrush}" Text="oder" />
                                <ui:Button Content="Sample wählen…" Icon="{ui:SymbolIcon FolderOpen24}"
                                           Command="{Binding ViewModel.BrowseSampleCommand}" />
                                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12" MaxWidth="220"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Text="{Binding ViewModel.SamplePath, TargetNullValue='noch kein Sample'}" />
                            </StackPanel>

                            <!-- 4 · Erstellen -->
                            <ui:Button Margin="0,16,0,0" HorizontalAlignment="Stretch" Appearance="Primary"
                                       Icon="{ui:SymbolIcon PersonVoice24}" Content="Stimme erstellen"
                                       Command="{Binding ViewModel.CreateProfileCommand}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,22,0,8">
                        <TextBlock Style="{StaticResource SectionCaption}" Margin="2,0,0,0" Text="DEINE STIMMEN" />
                    </StackPanel>
                    <ui:TextBox Margin="0,0,0,10" PlaceholderText="Vorschau-Text — wird bei ▶ mit der Stimme gesprochen"
                                Icon="{ui:SymbolIcon TextField24}"
                                Text="{Binding ViewModel.PreviewText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ItemsControl ItemsSource="{Binding ViewModel.Profiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="14,10" CornerRadius="10"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17" Margin="0,0,12,0"
                                                Background="{DynamicResource DawAccentSoftBrush}">
                                            <ui:SymbolIcon Symbol="PersonVoice24" FontSize="16"
                                                           Foreground="{DynamicResource DawAccentBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" Text="{Binding Description}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:Button Icon="{ui:SymbolIcon Play24}" ToolTip="Vorschau abspielen"
                                                       Command="{Binding DataContext.ViewModel.PreviewProfileCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" />
                                            <ui:Button Margin="6,0,0,0" Icon="{ui:SymbolIcon Delete24}" ToolTip="Stimme löschen"
                                                       Command="{Binding DataContext.ViewModel.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ————— RECHTS: Modelle ————— -->
                <StackPanel Grid.Column="2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource SectionCaption}" Text="VOICE-MODELLE" />
                        <ui:Button Margin="10,-6,0,0" Padding="6,2" Icon="{ui:SymbolIcon ArrowSync24}"
                                   ToolTip="Liste aktualisieren" Command="{Binding ViewModel.LoadModelsCommand}" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding ViewModel.Models}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="14,10" CornerRadius="10"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <Border Style="{StaticResource InstalledBadge}"
                                                        Visibility="{Binding Installed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="installiert" FontSize="10" Foreground="White" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <TextBlock FontSize="11" Margin="0,2,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Text="{Binding SizeText, StringFormat='≈ {0}'}" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" VerticalAlignment="Center" Icon="{ui:SymbolIcon ArrowDownload24}"
                                                   ToolTip="Modell herunterladen"
                                                   Command="{Binding DataContext.ViewModel.DownloadModelCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Margin="0,14,0,8">
                        <TextBlock Style="{StaticResource SectionCaption}" Margin="2,0,0,0" Text="WHISPER-MODELLE" />
                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Top" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="{Binding ViewModel.WhisperModel, StringFormat='aktiv: {0}'}" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding ViewModel.WhisperModelsList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="12,8" CornerRadius="10"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource InstalledBadge}"
                                                    Visibility="{Binding Installed, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="installiert" FontSize="10" Foreground="White" />
                                            </Border>
                                            <TextBlock Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Text="{Binding SizeText, StringFormat='≈ {0}'}" />
                                        </StackPanel>
                                        <ui:Button Grid.Column="1" VerticalAlignment="Center" Icon="{ui:SymbolIcon ArrowDownload24}"
                                                   ToolTip="Modell herunterladen"
                                                   Command="{Binding DataContext.ViewModel.DownloadModelCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
