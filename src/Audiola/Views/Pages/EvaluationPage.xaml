<Page
    x:Class="Audiola.Views.Pages.EvaluationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Title="EvaluationPage">

    <ScrollViewer Margin="42,24,42,24" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="860" HorizontalAlignment="Left">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Mess-Harness — Detektor-Zuverlässigkeit" />
            <TextBlock
                Margin="0,2,0,0"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap"
                Text="Lädt eine gelabelte CSV (Wahrheit vs. Detektor-Urteil/Score) und berechnet Konfusionsmatrix und Kennzahlen. Positivklasse = „KI“. Reine Auswertung — es wird kein Detektor aufgerufen." />

            <!-- Aktionen -->
            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon DocumentTable24}"
                           Content="CSV laden" Command="{Binding ViewModel.LoadCsvCommand}" />
                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" Text="{Binding ViewModel.StatusText}" />
            </StackPanel>

            <!-- Schwellwert (nur bei Score-Spalte) -->
            <Border Margin="0,16,0,0" Padding="16" CornerRadius="8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="{Binding ViewModel.HasScores, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding ViewModel.Threshold, StringFormat='Schwellwert (Score ≥ x ⇒ KI): {0:F2}'}" />
                    <Slider Minimum="0" Maximum="1" Value="{Binding ViewModel.Threshold, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Ergebnisse -->
            <Grid Margin="0,16,0,0"
                  Visibility="{Binding ViewModel.HasResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Konfusionsmatrix -->
                <Border Grid.Column="0" Padding="16" CornerRadius="8" VerticalAlignment="Top"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Konfusionsmatrix" Margin="0,0,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="110" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Urteil: KI" />
                            <TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Urteil: Mensch" />

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Wahr: KI" />
                            <Border Grid.Row="1" Grid.Column="1" Margin="2" Padding="0,14" CornerRadius="6" Background="#3328A745">
                                <StackPanel>
                                    <TextBlock HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="{Binding ViewModel.TruePositives}" />
                                    <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="TP" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="2" Margin="2" Padding="0,14" CornerRadius="6" Background="#33FF6B6B">
                                <StackPanel>
                                    <TextBlock HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="{Binding ViewModel.FalseNegatives}" />
                                    <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="FN" />
                                </StackPanel>
                            </Border>

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Wahr: Mensch" />
                            <Border Grid.Row="2" Grid.Column="1" Margin="2" Padding="0,14" CornerRadius="6" Background="#33FF6B6B">
                                <StackPanel>
                                    <TextBlock HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="{Binding ViewModel.FalsePositives}" />
                                    <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="FP" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="2" Margin="2" Padding="0,14" CornerRadius="6" Background="#3328A745">
                                <StackPanel>
                                    <TextBlock HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="{Binding ViewModel.TrueNegatives}" />
                                    <TextBlock HorizontalAlignment="Center" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="TN" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="{Binding ViewModel.Total, StringFormat='n = {0} bewertet'}" />
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Text="{Binding ViewModel.Skipped, StringFormat='{}{0} Zeilen ohne Urteil übersprungen'}" />
                    </StackPanel>
                </Border>

                <!-- Kennzahlen -->
                <Border Grid.Column="1" Margin="12,0,0,0" Padding="16" CornerRadius="8" VerticalAlignment="Top"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Kennzahlen" Margin="0,0,0,10" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding ViewModel.Accuracy}" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Accuracy (Treffergenauigkeit)" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding ViewModel.F1}" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="F1-Score" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding ViewModel.Recall}" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Recall / TPR (KI erkannt)" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding ViewModel.Precision}" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Precision" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FF8A8A" Text="{Binding ViewModel.FalsePositiveRate}" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="False-Positive-Rate (Mensch → KI)" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#FF8A8A" Text="{Binding ViewModel.FalseNegativeRate}" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="False-Negative-Rate (KI → Mensch)" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding ViewModel.Specificity}" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Specificity / TNR" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
