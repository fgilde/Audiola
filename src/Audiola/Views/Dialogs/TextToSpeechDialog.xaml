<ui:FluentWindow
    x:Class="Audiola.Views.Dialogs.TextToSpeechDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Audiola.Views.Dialogs"
    Title="Spur aus Text (Sprache)"
    Width="580" Height="760"
    MinWidth="440" MinHeight="520"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Spur aus Text (Sprache)">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="TextField24" /></ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" Margin="18,8,18,0">
            <TextBlock FontWeight="SemiBold" Text="Text" Margin="0,0,0,4" />
            <TextBox x:Name="TtsTextInput" MinHeight="90" MaxHeight="150" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Text="Hallo, das ist ein Test." />
            <TextBlock Margin="0,14,0,4" FontWeight="SemiBold" Text="Stimme" />
        </StackPanel>

        <local:VoiceSourcePicker Grid.Row="2" Margin="14,0,14,0" />

        <StackPanel Grid.Row="3" Margin="18,12,18,0">
            <TextBlock FontWeight="SemiBold" Text="Einstellungen" Margin="0,0,0,4" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="{Binding Value, ElementName=SpeedSlider, StringFormat='Geschwindigkeit: {0:F2}×'}" />
            <Slider x:Name="SpeedSlider" Minimum="0.7" Maximum="1.2" Value="1.0" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="{Binding Value, ElementName=StabilitySlider, StringFormat='Stabilität: {0:P0}'}" />
            <Slider x:Name="StabilitySlider" Minimum="0" Maximum="1" Value="0.5" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="{Binding Value, ElementName=SimilaritySlider, StringFormat='Ähnlichkeit: {0:P0}'}" />
            <Slider x:Name="SimilaritySlider" Minimum="0" Maximum="1" Value="0.75" />
        </StackPanel>

        <TextBlock Grid.Row="4" Margin="18,4,18,0" FontSize="12"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   Text="Die erzeugte Sprache wird als neue Spur in die Timeline gelegt." />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,10,18,16">
            <ui:ProgressRing Width="20" Height="20" Margin="0,0,12,0" IsIndeterminate="True"
                             Visibility="{Binding IsResolving, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <ui:Button Content="Abbrechen" Click="Cancel_Click" Margin="0,0,8,0"
                       IsEnabled="{Binding IsResolving, Converter={StaticResource InverseBooleanConverter}}" />
            <ui:Button Content="Erzeugen &amp; als Spur einfügen" Appearance="Primary" Click="Ok_Click"
                       IsEnabled="{Binding IsResolving, Converter={StaticResource InverseBooleanConverter}}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
