<ui:FluentWindow
    x:Class="Audiola.Views.Dialogs.SingAlongWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:Audiola.Controls"
    Title="Einsingen"
    Width="1040" Height="720"
    MinWidth="820" MinHeight="560"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <!-- Mute/Solo-Umschalter mit deutlichem Aktiv-Zustand (Farbe kommt aus Tag). -->
        <Style x:Key="TagToggle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" CornerRadius="6" Padding="7,3"
                                Background="#18FFFFFF" BorderThickness="1" BorderBrush="#22FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#55FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Spuren-Zeile: transparent, ausgewählte (= Gesangs-)Spur mit Akzent + linkem Balken. -->
        <Style x:Key="TrackRow" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource DawTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bd" CornerRadius="8" Padding="10,7"
                                Background="#12FFFFFF" BorderThickness="2,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#20FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A6BD6FF" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6BD6FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Einsingen">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="Mic24" /></ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Setup-Leiste: Mikrofon, Vorbereiten, Kalibrieren -->
        <Border Grid.Row="1" Margin="12,4,12,0" Padding="12,10" CornerRadius="10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock VerticalAlignment="Center" Text="Mikrofon:" FontSize="13" />
                <controls:MicSelectorControl Margin="8,0,0,0"
                                             DeviceNumber="{Binding SelectedMicNumber, Mode=TwoWay}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <ui:Button Icon="{ui:SymbolIcon MusicNote224}" Content="Backing vorbereiten"
                           Appearance="Primary" Command="{Binding PrepareCommand}" />
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon Timer24}" Content="Latenz kalibrieren"
                           Command="{Binding CalibrateCommand}"
                           ToolTip="Klick-Test — bitte OHNE Kopfhörer, damit das Mikro die Klicks hört." />
                <ui:Button Margin="8,0,0,0" Icon="{ui:SymbolIcon TextBulletListSquare24}" Content="Lyrics extrahieren"
                           Command="{Binding ExtractLyricsCommand}"
                           Visibility="{Binding NeedsLyrics, Converter={StaticResource BooleanToVisibilityConverter}}"
                           ToolTip="Liedtext aus der Gesangsspur erkennen (getaktet) und projektweit speichern." />
                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Text="{Binding LatencyMs, StringFormat='Versatz: {0:F0} ms'}" />
                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding CalibrationStatus}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Hauptbereich -->
        <Grid Grid.Row="2" Margin="12,8,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="264" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Spuren -->
            <Border Grid.Column="0" Padding="12" CornerRadius="10"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Text="Spuren" />
                    <TextBlock DockPanel.Dock="Top" Margin="0,2,0,8" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="Gesangsspur auswählen (liefert die Referenz-Melodie) und stummschalten, damit du nur das Playback hörst." />
                    <ListView ItemsSource="{Binding Tracks}" SelectedItem="{Binding ReferenceTrack, Mode=TwoWay}"
                              Background="Transparent" BorderThickness="0"
                              ItemContainerStyle="{StaticResource TrackRow}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                    <ToggleButton Grid.Column="1" Style="{StaticResource TagToggle}" Tag="#FF3B30" Content="M"
                                                  ToolTip="Stummschalten" IsChecked="{Binding IsMuted, Mode=TwoWay}" />
                                    <ToggleButton Grid.Column="2" Style="{StaticResource TagToggle}" Tag="#E0A800" Content="S"
                                                  ToolTip="Solo" IsChecked="{Binding IsSolo, Mode=TwoWay}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>

            <!-- Karaoke -->
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Score-Zeile -->
                <Border Grid.Row="0" Padding="14,10" CornerRadius="10"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Aufnahme-Indikator (blinkt während der Aufnahme) -->
                        <Border VerticalAlignment="Center" Margin="0,0,16,0" Padding="10,4" CornerRadius="14"
                                Background="#33FF3B30">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.3" Duration="0:0:0.6"
                                                                         AutoReverse="True" RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="#FF3B30" VerticalAlignment="Center" />
                                <TextBlock Margin="7,0,0,0" VerticalAlignment="Center" FontWeight="Bold"
                                           Foreground="#FF6B60" Text="AUFNAHME" />
                            </StackPanel>
                        </Border>
                        <TextBlock VerticalAlignment="Center" FontSize="26" FontWeight="Bold"
                                   Text="{Binding ScorePercent, StringFormat='{}{0}%'}" />
                        <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding Points, StringFormat='{}{0} Punkte'}" />
                        <Border Width="12" Height="12" Margin="20,0,0,0" CornerRadius="6" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource TextFillColorDisabledBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOnPitch}" Value="True">
                                            <Setter Property="Background" Value="#4CD964" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding TargetNote, StringFormat='Ziel {0}'}" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding SungNote, StringFormat='· Du {0}'}" />
                    </StackPanel>
                </Border>

                <!-- Lyrics -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock HorizontalAlignment="Center" FontSize="15" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding LyricPrev}" />
                    <TextBlock HorizontalAlignment="Center" Margin="0,4" FontSize="30" FontWeight="Bold"
                               TextWrapping="Wrap" TextAlignment="Center" Text="{Binding LyricCurrent}" />
                    <!-- Vorlauf: füllt sich bis zum Einsatz der nächsten Zeile -->
                    <ProgressBar Width="240" Height="5" Margin="0,6" HorizontalAlignment="Center"
                                 Minimum="0" Maximum="1" Value="{Binding NextLineProgress}"
                                 Foreground="#6BD6FF"
                                 Visibility="{Binding HasLyrics, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock HorizontalAlignment="Center" FontSize="16" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding LyricNext}" />
                </StackPanel>

                <!-- Pitch-Band -->
                <Border Grid.Row="2" Margin="0,8,0,0" CornerRadius="10" ClipToBounds="True" BorderThickness="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                    <Setter Property="BorderBrush" Value="#FF3B30" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <controls:PitchLaneControl />
                </Border>
            </Grid>
        </Grid>

        <!-- Transport -->
        <Border Grid.Row="3" Margin="12,8,12,12" Padding="14,10" CornerRadius="10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel>
                <!-- Positionsleiste: ziehen zum Springen (Punch-in). Aufnahme überschreibt ab hier. -->
                <Slider x:Name="PosSlider" Minimum="0" Maximum="{Binding DurationSeconds}"
                        Value="{Binding PositionSeconds, Mode=OneWay}" IsMoveToPointEnabled="True"
                        PreviewMouseLeftButtonDown="Pos_ScrubStart" PreviewMouseLeftButtonUp="Pos_ScrubEnd"
                        ToolTip="Ziehen zum Springen — an dieser Stelle aufnehmen überschreibt ab hier." />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <!-- Wiedergabe / Pause -->
                    <ui:Button MinWidth="150" Command="{Binding TogglePlayCommand}" IsEnabled="{Binding Prepared}">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Content" Value="▶  Wiedergabe" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Content" Value="⏸  Pause" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <!-- Aufnahme / Stopp -->
                    <ui:Button MinWidth="180" Margin="8,0,0,0" Appearance="Danger"
                               Command="{Binding ToggleRecordCommand}" IsEnabled="{Binding Prepared}">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Content" Value="⏺  Aufnahme" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Content" Value="⏹  Aufnahme stoppen" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsCountingIn}" Value="True">
                                        <Setter Property="Content" Value="✕  Vorzähler abbrechen" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                    <ui:ToggleSwitch Margin="12,0,0,0" VerticalAlignment="Center" Content="Vorzähler"
                                     IsChecked="{Binding CountInEnabled, Mode=TwoWay}"
                                     ToolTip="3-Sekunden-Countdown vor jeder Aufnahme" />
                    <TextBlock Margin="14,0,0,0" VerticalAlignment="Center" FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding PositionText}" />
                    <ui:Button Margin="20,0,0,0" Icon="{ui:SymbolIcon CheckmarkCircle24}" Content="Als Spur übernehmen"
                               Appearance="Success" Command="{Binding AcceptCommand}" />
                </StackPanel>
                <!-- „Perfekt machen": Auto-Tune auf die Original-Melodie + optionale Stimm-Veredelung -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <ui:Button Content="✨ Perfekt machen" Appearance="Primary"
                               Command="{Binding MakePerfectCommand}" IsEnabled="{Binding HasRecording}"
                               ToolTip="Zieht deine Aufnahme auf die Original-Melodie (deine Stimme bleibt) und übernimmt sie als neue Spur." />
                    <TextBlock Margin="16,0,6,0" VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Stärke" />
                    <Slider Width="120" VerticalAlignment="Center" Minimum="0" Maximum="1"
                            Value="{Binding MagicStrength, Mode=TwoWay}"
                            ToolTip="0 = unverändert, 1 = exakt auf der Melodie" />
                    <TextBlock Margin="16,0,6,0" VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="Veredeln mit" />
                    <ComboBox Width="200" ItemsSource="{Binding Voices}" DisplayMemberPath="Name"
                              SelectedItem="{Binding SelectedVoice, Mode=TwoWay}"
                              ToolTip="Optional: die korrigierte Stimme per seed-vc auf eine Zielstimme tauschen." />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Vorzähler-Overlay: 3-2-1 vor der Aufnahme (nochmal ⏺ drücken bricht ab) -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#90000000" IsHitTestVisible="False"
                Visibility="{Binding IsCountingIn, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock FontSize="128" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"
                           Text="{Binding CountIn}" />
                <TextBlock Margin="0,4,0,0" FontSize="16" Foreground="#CCFFFFFF" HorizontalAlignment="Center"
                           Text="Bereit machen — die Aufnahme startet gleich" />
            </StackPanel>
        </Border>

        <!-- Busy-Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="#B0000000"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="46" Height="46" HorizontalAlignment="Center" />
                <TextBlock Margin="0,14,0,0" Foreground="White" Text="{Binding Status}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
