<ui:FluentWindow
    x:Class="Audiola.Views.Dialogs.VoiceSwapDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Audiola.Views.Dialogs"
    Title="Stimme tauschen"
    Width="540" Height="540"
    MinWidth="420" MinHeight="420"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Stimme tauschen">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="PersonVoice24" /></ui:TitleBar.Icon>
        </ui:TitleBar>

        <TextBlock Grid.Row="1" Margin="18,8,18,0" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Speech-to-Speech über ElevenLabs: Performance/Timing/Betonung (auch Gesang) bleiben, nur die Klangfarbe wird zur Zielstimme. Am besten auf einer isolierten Vocal-Spur. Zielstimme wählen, aufnehmen oder als Datei hochladen." />

        <local:VoiceSourcePicker Grid.Row="2" Margin="14,10,14,0" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="18,8,18,16">
            <ui:ProgressRing Width="20" Height="20" Margin="0,0,12,0" IsIndeterminate="True"
                             Visibility="{Binding IsResolving, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <ui:Button Content="Abbrechen" Click="Cancel_Click" Margin="0,0,8,0"
                       IsEnabled="{Binding IsResolving, Converter={StaticResource InverseBooleanConverter}}" />
            <ui:Button Content="Übernehmen" Appearance="Primary" Click="Ok_Click"
                       IsEnabled="{Binding IsResolving, Converter={StaticResource InverseBooleanConverter}}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
