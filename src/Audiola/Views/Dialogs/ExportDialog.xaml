<ui:FluentWindow
    x:Class="Audiola.Views.Dialogs.ExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Exportieren"
    Width="620" Height="720"
    MinWidth="460" MinHeight="480"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Exportieren">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="ArrowExportLtr24" /></ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Format + Bitrate -->
        <Grid Grid.Row="1" Margin="18,8,18,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock FontWeight="SemiBold" Text="Format" Margin="0,0,0,4" />
                <ComboBox x:Name="FormatBox" SelectedIndex="0" Width="180" HorizontalAlignment="Left"
                          SelectionChanged="Format_Changed">
                    <ComboBoxItem Content="WAV (unkomprimiert)" Tag="wav" />
                    <ComboBoxItem Content="MP3" Tag="mp3" />
                    <ComboBoxItem Content="M4A / AAC" Tag="m4a" />
                    <ComboBoxItem Content="FLAC (verlustfrei)" Tag="flac" />
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" x:Name="BitratePanel">
                <TextBlock FontWeight="SemiBold" Text="Bitrate" Margin="0,0,0,4" />
                <ComboBox x:Name="BitrateBox" SelectedIndex="2" Width="120" HorizontalAlignment="Left">
                    <ComboBoxItem Content="128 kbps" Tag="128000" />
                    <ComboBoxItem Content="192 kbps" Tag="192000" />
                    <ComboBoxItem Content="256 kbps" Tag="256000" />
                    <ComboBoxItem Content="320 kbps" Tag="320000" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <ui:InfoBar Grid.Row="1" Margin="18,72,18,0" VerticalAlignment="Top"
                    x:Name="WavHint" IsOpen="False" IsClosable="False" Severity="Informational"
                    Title="Hinweis zu WAV"
                    Message="WAV speichert Tags/Cover/Lyrics nur eingeschränkt. Für vollständige Metadaten MP3, M4A oder FLAC wählen (eine .lrc-Datei wird zusätzlich daneben gespeichert)." />

        <!-- Metadaten -->
        <ui:DynamicScrollViewer Grid.Row="2" Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
            <Grid Margin="18,8,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Cover -->
                <StackPanel Grid.Row="0" Grid.Column="0" Width="140" Margin="0,0,16,0">
                    <Border Width="140" Height="140" CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <Grid>
                            <ui:SymbolIcon Symbol="Image24" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Visibility="{Binding Meta.HasCover, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            <Image Stretch="UniformToFill"
                                   Source="{Binding Meta.CoverArt, Converter={StaticResource BytesToImageConverter}}" />
                        </Grid>
                    </Border>
                    <ui:Button Margin="0,8,0,0" HorizontalAlignment="Stretch" Icon="{ui:SymbolIcon Image24}"
                               Content="Cover wählen" Click="ChooseCover_Click" />
                    <ui:Button Margin="0,6,0,0" HorizontalAlignment="Stretch" Appearance="Secondary"
                               Icon="{ui:SymbolIcon Delete24}" Content="Entfernen" Click="RemoveCover_Click"
                               Visibility="{Binding Meta.HasCover, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>

                <!-- Tag-Felder -->
                <StackPanel Grid.Row="0" Grid.Column="1">
                    <TextBlock FontWeight="SemiBold" Text="Titel" />
                    <ui:TextBox Margin="0,2,0,8" Text="{Binding Meta.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock FontWeight="SemiBold" Text="Interpret" />
                    <ui:TextBox Margin="0,2,0,8" Text="{Binding Meta.Artist, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock FontWeight="SemiBold" Text="Album" />
                    <ui:TextBox Margin="0,2,0,8" Text="{Binding Meta.Album, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock FontWeight="SemiBold" Text="Genre" />
                            <ui:TextBox Margin="0,2,0,8" Text="{Binding Meta.Genre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock FontWeight="SemiBold" Text="Jahr" />
                            <ui:TextBox Margin="0,2,0,8" Text="{Binding Meta.Year, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock FontWeight="SemiBold" Text="Track" />
                            <ui:TextBox Margin="0,2,0,8" Text="{Binding Meta.TrackNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock FontWeight="SemiBold" Text="Album-Interpret" />
                    <ui:TextBox Margin="0,2,0,8" Text="{Binding Meta.AlbumArtist, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock FontWeight="SemiBold" Text="Kommentar" />
                    <ui:TextBox Margin="0,2,0,8" Text="{Binding Meta.Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- Lyrics -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:ToggleSwitch x:Name="EmbedLyricsToggle" IsChecked="True" Content="Liedtext einbetten" />
                        <ui:Button Margin="16,0,0,0" Appearance="Secondary" Icon="{ui:SymbolIcon Wand24}"
                                   x:Name="GenerateLyricsButton" Content="Erzeugen (Whisper)"
                                   Click="GenerateLyrics_Click" Visibility="Collapsed" />
                        <ui:Button Margin="8,0,0,0" Appearance="Secondary" Icon="{ui:SymbolIcon Cloud24}"
                                   x:Name="GenerateLyricsElevenButton" Content="via ElevenLabs" Tag="eleven"
                                   Click="GenerateLyrics_Click" Visibility="Collapsed" />
                        <ui:ProgressRing x:Name="LyricsBusy" Width="20" Height="20" Margin="10,0,0,0"
                                         IsIndeterminate="True" Visibility="Collapsed" />
                    </StackPanel>
                    <ui:TextBox Margin="0,6,0,0" MinHeight="110" MaxHeight="220" AcceptsReturn="True" TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                PlaceholderText="Liedtext (optional, LRC mit Zeitstempeln wird unterstützt)"
                                Text="{Binding Meta.Lyrics, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>
        </ui:DynamicScrollViewer>

        <!-- Aktionen -->
        <Border Grid.Row="3" Padding="18,12" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:ProgressRing x:Name="PreviewBusy" Width="20" Height="20" Margin="0,0,10,0"
                                 VerticalAlignment="Center" IsIndeterminate="True" Visibility="Collapsed" />
                <ui:Button x:Name="PreviewButton" Icon="{ui:SymbolIcon Eye24}" Content="Vorschau"
                           Click="Preview_Click" Margin="0,0,8,0" Visibility="Collapsed"
                           ToolTip="Datei mit den aktuellen Tags &amp; Lyrics erzeugen und im Browser ansehen" />
                <ui:Button Content="Abbrechen" Click="Cancel_Click" Margin="0,0,8,0" />
                <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon Save24}" Content="Exportieren…" Click="Export_Click" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
