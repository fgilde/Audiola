<ui:FluentWindow
    x:Class="Audiola.Views.Dialogs.TrackMasteringDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:Audiola.Controls"
    Title="Spur mastern"
    Width="820" Height="760"
    MinWidth="560" MinHeight="520"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="None"
    Background="{StaticResource DawBgBrush}"
    WindowCornerPreference="Round">

    <Grid TextElement.Foreground="{StaticResource DawTextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Spur mastern">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="SoundWaveCircle24" /></ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Dasselbe Mastering-Panel wie auf der Mastering-Seite — inkl. Wellenform mit Seek,
             Live-A/B, Presets, EQ-Kurve, Kompressor und LUFS. Quelle: die gewählte Spur (solo).
             Die Aktionen liegen hier im Dialog-Footer (Anwenden/Abbrechen). -->
        <ui:DynamicScrollViewer Grid.Row="1" Margin="0,4,0,0" VerticalScrollBarVisibility="Auto">
            <controls:MasteringPanel Margin="18,4,18,10" ShowActions="False" />
        </ui:DynamicScrollViewer>

        <Border Grid.Row="2" Padding="18,12" Background="{StaticResource DawPanelBrush}"
                BorderBrush="{StaticResource DawStrokeBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <!-- Sekundär: gemasterte Spur als Datei exportieren -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ui:Button Icon="{ui:SymbolIcon Save24}" Content="Als Datei exportieren"
                               Command="{Binding ExportCommand}"
                               ToolTip="Die gemasterte Spur als Audiodatei speichern (ohne die Spur im Studio zu ändern)" />
                    <ui:ProgressRing Margin="12,0,0,0" Width="22" Height="22" VerticalAlignment="Center" IsIndeterminate="True"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
                <!-- Primär: Anwenden / Abbrechen -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon CheckmarkCircle24}" Content="Anwenden"
                               Command="{Binding ApplyToTrackCommand}"
                               ToolTip="Spur mastern und im Studio ersetzen (Strg+Z macht es rückgängig)" />
                    <ui:Button Margin="8,0,0,0" Content="Abbrechen" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
